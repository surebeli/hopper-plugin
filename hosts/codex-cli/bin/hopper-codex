#!/usr/bin/env bash
# hopper-codex — Tier C Codex CLI host adapter for hopper-plugin
# Anchor: hosts/codex-cli/bin/hopper-codex
#
# Per spec §1 #2 cross-host architecture + §3 #4 no harness reaction core:
# this wrapper is a THIN bridge. It:
#   1. Validates the task-id and flags (same regex/whitelist as Claude Code dispatch.md)
#   2. Resolves the host-agnostic hopper-dispatch path
#   3. Invokes codex CLI with a prompt that tells codex to run hopper-dispatch via shell tool
#
# Single-spawn invariant: this wrapper invokes codex ONCE. codex itself spawns
# hopper-dispatch ONCE (its own internal tool-use). hopper-dispatch spawns the
# vendor adapter subprocess ONCE. No retry anywhere in the chain.
#
# Usage:
#   hopper-codex <task-id> [--write] [--force]

set -eu

usage() {
  cat <<EOF >&2
hopper-codex — Tier C Codex CLI host adapter for hopper-plugin

Usage: hopper-codex <task-id> [--write] [--force]

Arguments:
  <task-id>   Task ID matching ^[A-Za-z][A-Za-z0-9._-]{0,99}$
  --write     Write .hopper/handoffs/<task-id>-output.md after dispatch
  --force     Overwrite existing output.md (only with --write)

Environment:
  HOPPER_PLUGIN_ROOT   Override plugin root (defaults to wrapper-relative)
  HOPPER_DIR           Override .hopper/ location (passed through to hopper-dispatch)
  CODEX_REASONING      Codex reasoning effort (default: medium)
EOF
}

if [ $# -lt 1 ] || [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
  usage
  exit 1
fi

TASK_ID="$1"
shift

# Per Phase 3 audit F2 echo: validate before passing to a subprocess.
if ! printf '%s' "$TASK_ID" | grep -Eq '^[A-Za-z][A-Za-z0-9._-]{0,99}$'; then
  echo "Error: task-id '$TASK_ID' must match ^[A-Za-z][A-Za-z0-9._-]{0,99}$" >&2
  exit 2
fi

# Validate each remaining flag against an explicit whitelist
FLAGS=""
for flag in "$@"; do
  case "$flag" in
    --write|--force)
      FLAGS="$FLAGS $flag"
      ;;
    *)
      echo "Error: invalid flag '$flag'. Only --write and --force are allowed." >&2
      exit 2
      ;;
  esac
done

# Locate plugin root (where .claude-plugin/ and cli/bin/hopper-dispatch live)
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
if [ -n "${HOPPER_PLUGIN_ROOT:-}" ]; then
  PLUGIN_ROOT="$HOPPER_PLUGIN_ROOT"
else
  # wrapper is at hosts/codex-cli/bin/hopper-codex; plugin root is 3 levels up
  PLUGIN_ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"
fi

DISPATCH="$PLUGIN_ROOT/cli/bin/hopper-dispatch"
if [ ! -f "$DISPATCH" ]; then
  echo "Error: hopper-dispatch not found at $DISPATCH" >&2
  echo "Set HOPPER_PLUGIN_ROOT env var to the plugin root if installed elsewhere." >&2
  exit 3
fi

# Verify codex CLI is on PATH
if ! command -v codex >/dev/null 2>&1; then
  echo "Error: codex CLI not found in PATH. Install codex (https://openai.com/codex/cli) before using Tier C." >&2
  exit 4
fi

REASONING="${CODEX_REASONING:-medium}"

# Build the codex prompt. The prompt instructs codex to invoke hopper-dispatch
# via its built-in shell tool, then summarize the result. Codex acts as the
# host (provides the reasoning loop + tool dispatch); hopper-dispatch handles
# the single subprocess vendor spawn.
PROMPT="Run the following exact shell command via your shell tool, then surface its output to the user verbatim:

node \"$DISPATCH\" \"$TASK_ID\"$FLAGS

After the command returns, do this:

1. If exit code is 0 and the user passed --write, locate the 'Suggested queue.md edit' and 'Suggested COST-LOG.md row' blocks in stdout. Print them to the user. Then state:

   'Per hopper-plugin spec §11 unified user-action gate, apply these edits only after manual review. I will not apply them automatically.'

2. If exit code is non-zero, surface the error block verbatim. Do NOT retry the command — per spec §3 #4, the dispatcher's single-spawn invariant means retries belong to the user, not the host adapter.

3. Do NOT call any other shell commands except the one specified above. Do NOT modify .hopper/queue.md, .hopper/AGENTS.md, or .hopper/COST-LOG.md."

# Invoke codex once; sandbox is read-only by default — user must opt into
# workspace-write only if their codex install requires it for the shell tool.
exec codex exec -s "${CODEX_SANDBOX:-workspace-write}" -c "model_reasoning_effort=\"$REASONING\"" "$PROMPT"
