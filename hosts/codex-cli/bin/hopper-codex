#!/usr/bin/env bash
# hopper-codex — Tier C Codex CLI host adapter for hopper-plugin
# Anchor: hosts/codex-cli/bin/hopper-codex
#
# Per spec §1 #2 cross-host architecture + §3 #4 no harness reaction core:
# this wrapper is a THIN bridge. It:
#   1. Validates the task-id and flags (same regex/whitelist as Claude Code dispatch.md)
#   2. Resolves the host-agnostic hopper-dispatch path
#   3. Invokes codex CLI with a prompt that tells codex to run hopper-dispatch via shell tool
#
# Single-spawn invariant: this wrapper invokes codex ONCE. codex itself spawns
# hopper-dispatch ONCE (its own internal tool-use). hopper-dispatch spawns the
# vendor adapter subprocess ONCE. No retry anywhere in the chain.
#
# Usage:
#   hopper-codex <task-id> [--write] [--force]

set -eu

usage() {
  cat <<EOF >&2
hopper-codex — Tier C Codex CLI host adapter for hopper-plugin

Usage: hopper-codex <task-id> [--write] [--force] [--model <name>] [--reasoning <level>]

Arguments:
  <task-id>           Task ID matching ^[A-Za-z][A-Za-z0-9._-]{0,99}$
  --write             Write .hopper/handoffs/<task-id>-output.md after dispatch
  --force             Overwrite existing output.md (only with --write)
  --model <name>      Forward to vendor adapter (honored by kimi/opencode/copilot/grok)
  --reasoning <lv>    Forward reasoning effort: minimal|low|medium|high|xhigh (honored by codex adapter)

Environment:
  HOPPER_PLUGIN_ROOT   Override plugin root (defaults to wrapper-relative)
  HOPPER_DIR           Override .hopper/ location (passed through to hopper-dispatch)
  CODEX_REASONING      OUTER codex CLI reasoning (the codex driving the dispatch loop, not the vendor)
  CODEX_SANDBOX        OUTER codex sandbox mode (default workspace-write)
EOF
}

if [ $# -lt 1 ] || [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
  usage
  exit 1
fi

TASK_ID="$1"
shift

# Per Phase 3 audit F2 echo + T-08a audit F1 (cross-host parity):
# validate against the SAME rules as Claude Code dispatch.md.
if ! printf '%s' "$TASK_ID" | grep -Eq '^[A-Za-z][A-Za-z0-9._-]{0,99}$'; then
  echo "Error: task-id '$TASK_ID' must match ^[A-Za-z][A-Za-z0-9._-]{0,99}$" >&2
  exit 2
fi
# Per T-08a audit P1 F1: ALSO reject '..' (path traversal) — matches
# Claude Code dispatch.md cross-host parity. Regex alone allows '.' which
# means 'T..x' passes the pattern; explicit '..' check closes that gap.
case "$TASK_ID" in
  *..*)
    echo "Error: task-id '$TASK_ID' must not contain '..' (path traversal)" >&2
    exit 2
    ;;
esac

# Validate flags against explicit whitelist + parse value-taking flags.
# Bare flags: --write, --force, --background. Value flags: --model, --reasoning.
# Same validation rules as Claude Code dispatch.md + Tier A hopper-dispatch.
FLAGS=""
while [ $# -gt 0 ]; do
  case "$1" in
    --write|--force|--background)
      FLAGS="$FLAGS $1"
      shift
      ;;
    --model)
      shift
      if [ $# -eq 0 ] || [ -z "${1:-}" ] || [ "${1#-}" != "$1" ]; then
        echo "Error: --model requires a value." >&2
        exit 2
      fi
      if ! printf '%s' "$1" | grep -Eq '^[A-Za-z][A-Za-z0-9._/:-]{0,99}$'; then
        echo "Error: --model value '$1' contains unsafe characters." >&2
        exit 2
      fi
      FLAGS="$FLAGS --model $1"
      shift
      ;;
    --reasoning)
      shift
      case "${1:-}" in
        minimal|low|medium|high|xhigh)
          FLAGS="$FLAGS --reasoning $1"
          shift
          ;;
        *)
          echo "Error: --reasoning must be one of minimal|low|medium|high|xhigh (got: ${1:-empty})." >&2
          exit 2
          ;;
      esac
      ;;
    *)
      echo "Error: invalid flag '$1'. Allowed: --write, --force, --background, --model <name>, --reasoning <level>." >&2
      exit 2
      ;;
  esac
done

# Per spec §14.7: signal heterogeneous-only constraint via env var
export HOPPER_HOST_VENDOR=codex

# Locate plugin root (where .claude-plugin/ and cli/bin/hopper-dispatch live).
# Per T-08a audit P1 F2: when the wrapper is installed via symlink onto PATH,
# $0 / dirname $0 returns the SYMLINK location, not the actual script. The
# wrapper-relative '../../..' resolution then points at the symlink-tree
# parent, breaking the install. Resolve the real script path first.
resolve_script_dir() {
  local src="$1"
  # Walk symlinks until we hit the real file. Portable across Linux/macOS
  # (BSD readlink lacks -f).
  while [ -L "$src" ]; do
    local link
    link="$(readlink "$src")"
    case "$link" in
      /*) src="$link" ;;
      *)  src="$(dirname "$src")/$link" ;;
    esac
  done
  cd "$(dirname "$src")" && pwd
}

SCRIPT_DIR="$(resolve_script_dir "$0")"
if [ -n "${HOPPER_PLUGIN_ROOT:-}" ]; then
  PLUGIN_ROOT="$HOPPER_PLUGIN_ROOT"
else
  # wrapper is at hosts/codex-cli/bin/hopper-codex; plugin root is 3 levels up
  # from the REAL script location (post symlink resolution above).
  PLUGIN_ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"
fi

DISPATCH="$PLUGIN_ROOT/cli/bin/hopper-dispatch"
if [ ! -f "$DISPATCH" ]; then
  echo "Error: hopper-dispatch not found at $DISPATCH" >&2
  echo "Set HOPPER_PLUGIN_ROOT env var to the plugin root if installed elsewhere." >&2
  exit 3
fi

# Verify codex CLI is on PATH
if ! command -v codex >/dev/null 2>&1; then
  echo "Error: codex CLI not found in PATH. Install codex (https://openai.com/codex/cli) before using Tier C." >&2
  exit 4
fi

REASONING="${CODEX_REASONING:-medium}"

# Build the codex prompt. The prompt instructs codex to invoke hopper-dispatch
# via its built-in shell tool, then summarize the result. Codex acts as the
# host (provides the reasoning loop + tool dispatch); hopper-dispatch handles
# the single subprocess vendor spawn.
PROMPT="Run the following exact shell command via your shell tool, then surface its output to the user verbatim:

node \"$DISPATCH\" \"$TASK_ID\"$FLAGS

After the command returns, do this:

1. If exit code is 0 and the user passed --write, locate the 'Suggested queue.md edit' and 'Suggested COST-LOG.md row' blocks in stdout. Print them to the user. Then state:

   'Per hopper-plugin spec §11 unified user-action gate, apply these edits only after manual review. I will not apply them automatically.'

2. If exit code is non-zero, surface the error block verbatim. Do NOT retry the command — per spec §3 #4, the dispatcher's single-spawn invariant means retries belong to the user, not the host adapter.

3. Do NOT call any other shell commands except the one specified above. Do NOT modify .hopper/queue.md, .hopper/AGENTS.md, or .hopper/COST-LOG.md.

4. Do NOT diagnose the failure, propose fixes, or suggest next steps. Your role is dispatch + surface, not orchestrate. If the user wants diagnosis they will ask explicitly. Per spec §3 #4, advice that nudges the user toward retries or vendor-switches is soft-orchestration and is forbidden in this host adapter."

# Sandbox: default workspace-write because codex's shell tool needs to spawn
# hopper-dispatch (which writes inside `.hopper/handoffs/`). The workspace-write
# sandbox restricts writes to $CWD only; codex cannot touch files outside.
# Per codex final strict audit P1: this is intentional and disclosed — codex
# has write access to the workspace, but the prompt explicitly constrains its
# behavior to "dispatch + surface only". The sandbox is the second line of
# defense; the prompt is the first. User can override via CODEX_SANDBOX env.
exec codex exec -s "${CODEX_SANDBOX:-workspace-write}" -c "model_reasoning_effort=\"$REASONING\"" "$PROMPT"
