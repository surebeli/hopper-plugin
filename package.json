{
  "name": "hopper-plugin",
  "version": "0.18.0",
  "description": "Reference implementation of llm-hopper protocol as a thin plugin layer. No harness reaction core; vendor CLIs bring their own runtime.",
  "type": "module",
  "bin": {
    "hopper-dispatch": "./cli/bin/hopper-dispatch",
    "hopper-dashboard": "./cli/bin/hopper-dashboard"
  },
  "scripts": {
    "smoke": "node cli/bin/hopper-dispatch --smoke",
    "sync:plugin": "node scripts/sync-vendored-plugin.mjs",
    "test": "node --test tests/unit/*.test.js",
    "test:queue": "node --test tests/unit/queue.test.js",
    "test:tasks": "node --test tests/unit/tasks.test.js",
    "test:agents": "node --test tests/unit/agents.test.js",
    "test:subprocess": "node --test tests/unit/subprocess.test.js",
    "dashboard:dev": "node cli/bin/hopper-dashboard --dev",
    "dashboard:build": "cd dashboard/client && tsc -p tsconfig.json --noEmit && vite build",
    "dashboard:start": "node cli/bin/hopper-dashboard"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "@tanstack/react-query": "^5.51.0",
    "@tanstack/react-table": "^8.20.0",
    "chokidar": "^3.6.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "express": "^4.19.0",
    "highlight.js": "^11.10.0",
    "lucide-react": "^0.400.0",
    "markdown-it": "^14.1.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.26.0",
    "sonner": "^1.5.0",
    "tailwind-merge": "^2.4.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  },
  "author": "surebeli (litianyi)",
  "license": "Apache-2.0",
  "homepage": "https://github.com/surebeli/hopper-plugin",
  "repository": {
    "type": "git",
    "url": "https://github.com/surebeli/hopper-plugin.git"
  }
}
