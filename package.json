{
  "name": "hopper-plugin",
  "version": "0.6.0-phase-6c",
  "description": "Reference implementation of llm-hopper protocol as a thin plugin layer. No harness reaction core; vendor CLIs bring their own runtime.",
  "type": "module",
  "bin": {
    "hopper-dispatch": "./cli/bin/hopper-dispatch"
  },
  "scripts": {
    "smoke": "node cli/bin/hopper-dispatch --smoke",
    "test": "node --test tests/unit/*.test.js",
    "test:queue": "node --test tests/unit/queue.test.js",
    "test:tasks": "node --test tests/unit/tasks.test.js",
    "test:agents": "node --test tests/unit/agents.test.js",
    "test:subprocess": "node --test tests/unit/subprocess.test.js"
  },
  "engines": {
    "node": ">=18"
  },
  "author": "surebeli (litianyi)",
  "license": "Apache-2.0",
  "homepage": "https://github.com/surebeli/hopper-plugin",
  "repository": {
    "type": "git",
    "url": "https://github.com/surebeli/hopper-plugin.git"
  }
}
