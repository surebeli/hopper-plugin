#!/usr/bin/env node
// hopper-runner — detached wrapper owning a single vendor subprocess lifecycle
// Anchor: cli/bin/hopper-runner
//
// Per spec v2.1.0 §14.6: this wrapper is invoked exclusively by hopper-dispatch
// --background as a detached child. It then spawns the vendor adapter EXACTLY
// ONCE (non-detached, so this wrapper owns the lifecycle), waits for vendor
// exit, and atomically updates the output.md frontmatter status.
//
// Single-spawn invariant: this script contains exactly one spawn() call.
// Counter-tested in tests/integration/runner-single-spawn.test.js.

import { spawn, execSync } from 'node:child_process';
import { openSync, closeSync, readFileSync, existsSync } from 'node:fs';
import { readFrontmatter, writeFrontmatter } from '../src/background.js';
import { getAdapter } from '../src/vendors/index.js';

/**
 * Windows .cmd/.bat lookup: CreateProcessW can directly execute .exe but
 * NOT .cmd or .bat. When the command is unqualified, use `where` to resolve.
 * If the resolved file is .exe → use it directly. If .cmd/.bat → wrap with
 * cmd.exe /c (preserves single-spawn invariant; still one spawn — just one
 * level of shell indirection for command resolution).
 *
 * Returns { command, prependArgs }. Returns command unchanged on POSIX.
 */
function resolveWindowsCommand(cmd) {
  if (process.platform !== 'win32') return { command: cmd, prependArgs: [] };
  // If already a path or already has extension, trust it
  if (cmd.includes('/') || cmd.includes('\\') || /\.\w+$/.test(cmd)) {
    return { command: cmd, prependArgs: [] };
  }
  try {
    const out = execSync(`where ${cmd}`, { encoding: 'utf-8', stdio: ['ignore', 'pipe', 'ignore'] });
    const lines = out.split(/\r?\n/).map(l => l.trim()).filter(Boolean);
    // Prefer .exe (executable directly by CreateProcessW)
    const exe = lines.find(l => l.toLowerCase().endsWith('.exe'));
    if (exe) return { command: exe, prependArgs: [] };
    // Fall back to .cmd/.bat → wrap with cmd.exe
    const batch = lines.find(l => /\.(cmd|bat)$/i.test(l));
    if (batch) return { command: process.env.ComSpec || 'cmd.exe', prependArgs: ['/c', batch] };
  } catch (_) {
    // `where` failed — return original; CreateProcessW will likely fail too
  }
  return { command: cmd, prependArgs: [] };
}

function parseRunnerArgs(argv) {
  // Format: --task-id X --hopper-dir Y --adapter Z --output-md A --log B -- <adapter argv...>
  const parsed = { adapterArgv: [] };
  let i = 0;
  let sawSeparator = false;
  while (i < argv.length) {
    const a = argv[i];
    if (sawSeparator) {
      parsed.adapterArgv.push(a);
      i++;
      continue;
    }
    if (a === '--') {
      sawSeparator = true;
      i++;
      continue;
    }
    if (a.startsWith('--')) {
      const key = a.slice(2).replace(/-([a-z])/g, (_, c) => c.toUpperCase());
      const val = argv[i + 1];
      if (val === undefined || val.startsWith('--')) {
        throw new Error(`hopper-runner: flag ${a} requires a value`);
      }
      parsed[key] = val;
      i += 2;
      continue;
    }
    throw new Error(`hopper-runner: unexpected arg ${a}`);
  }
  return parsed;
}

function fail(outputMdPath, message) {
  // best-effort frontmatter update on early failure
  try {
    const fm = readFrontmatter(outputMdPath);
    writeFrontmatter(outputMdPath, {
      ...fm,
      status: 'failed',
      end_time: new Date().toISOString(),
      exit_code: -1,
      duration_ms: Date.now() - Date.parse(fm.start_time || new Date().toISOString()),
      _body: (fm._body || '') + `\n## Failure (runner)\n${message}\n`,
    });
  } catch (_) {
    // if we can't even write frontmatter, all we can do is exit
  }
  process.stderr.write(`hopper-runner: ${message}\n`);
  process.exit(1);
}

async function main() {
  let opts;
  try {
    opts = parseRunnerArgs(process.argv.slice(2));
  } catch (err) {
    process.stderr.write(`${err.message}\n`);
    process.exit(2);
  }

  const { taskId, hopperDir, adapter: adapterName, outputMd: outputMdPath, log: logPath, adapterArgv } = opts;
  if (!taskId || !hopperDir || !adapterName || !outputMdPath || !logPath) {
    process.stderr.write('hopper-runner: missing required flags (--task-id, --hopper-dir, --adapter, --output-md, --log)\n');
    process.exit(2);
  }

  const adapter = getAdapter(adapterName);
  if (!adapter) {
    fail(outputMdPath, `Unknown adapter: ${adapterName}`);
  }

  const t0 = Date.now();

  // Open log fds for vendor stdio. The runner's own stdout/stderr was already
  // redirected to logPath by the parent (hopper-dispatch). We re-open the file
  // for the vendor so its writes are tracked separately for failure analysis.
  let fdOut, fdErr;
  try {
    fdOut = openSync(logPath, 'a');
    fdErr = openSync(logPath, 'a');
  } catch (err) {
    fail(outputMdPath, `Could not open log file ${logPath}: ${err.message}`);
  }

  // Windows .cmd resolution: kimi.exe spawns directly; codex.cmd needs
  // cmd.exe /c wrapper. Resolved synchronously via `where`. Real-exe path
  // is used directly when available (no shell wrap).
  const { command: resolvedCmd, prependArgs } = resolveWindowsCommand(adapter.command);
  const finalArgv = [...prependArgs, ...adapterArgv];

  // *** THE single spawn (spec §3 #4) ***
  // Single spawn() call. Windows command resolution above is a pure-sync
  // PATH lookup, not a spawn (uses execSync only for `where`).
  const vendor = spawn(resolvedCmd, finalArgv, {
    stdio: ['ignore', fdOut, fdErr],
    windowsHide: true,
    cwd: process.cwd(),
    env: process.env,
  });

  // Close our copies of the fds; vendor has its own.
  closeSync(fdOut);
  closeSync(fdErr);

  let timedOut = false;
  const timeoutMs = adapter.timeoutMs({ background: true });
  const killTimer = setTimeout(() => {
    timedOut = true;
    try { vendor.kill('SIGTERM'); } catch (_) {}
    // Hard-kill after 5s grace
    setTimeout(() => { try { vendor.kill('SIGKILL'); } catch (_) {} }, 5000).unref();
  }, timeoutMs);
  killTimer.unref();

  vendor.on('exit', (code, signal) => {
    clearTimeout(killTimer);
    const duration_ms = Date.now() - t0;

    // Per codex Phase 5 audit P1 #2: read log + invoke adapter.parseResult
    // so exit-0 failure modes (kimi HTTP 402, agy silent auth-fail) are
    // classified correctly. Without this, false-success status leaks through.
    let stdoutTail = '';
    let stderrTail = '';
    let logFileContent;
    try {
      if (existsSync(logPath)) {
        const full = readFileSync(logPath, 'utf-8');
        // log holds BOTH stdout and stderr interleaved; pass it as both for
        // adapters that pattern-match (kimi looks at stdout; agy at stderr/log)
        stdoutTail = full;
        stderrTail = full;
        logFileContent = full;
      }
    } catch (_) {
      // log unreadable; fall back to exit-code-only classification
    }

    let adapterStatus;
    let adapterError;
    try {
      const parsed = adapter.parseResult({
        exitCode: code === null ? -1 : code,
        stdout: stdoutTail,
        stderr: stderrTail,
        timedOut,
        durationMs: duration_ms,
        logFileContent,
      });
      adapterStatus = parsed.status;       // success | auth-fail | timeout | permission-fail | unknown-fail
      adapterError = parsed.error || null;
    } catch (err) {
      adapterStatus = 'unknown-fail';
      adapterError = `parseResult threw: ${err.message}`;
    }

    // Map adapter classification → queue-legal status (per spec §14.4)
    let status;
    if (adapterStatus === 'success') status = 'done';
    else status = 'failed';                // auth-fail / timeout / permission-fail / unknown-fail → failed

    try {
      const fm = readFrontmatter(outputMdPath);
      writeFrontmatter(outputMdPath, {
        ...fm,
        status,
        end_time: new Date().toISOString(),
        exit_code: code === null ? -1 : code,
        signal: signal || null,
        timed_out: timedOut || null,
        duration_ms,
        adapter_status: adapterStatus,     // preserve the granular classification
        _body: (fm._body || '') +
          `\n## Status (background completion)\n` +
          `- queue_status: ${status}\n` +
          `- adapter_status: ${adapterStatus}\n` +
          `- exit_code: ${code === null ? -1 : code}\n` +
          (signal ? `- signal: ${signal}\n` : '') +
          (timedOut ? `- timed_out: true\n` : '') +
          `- duration_ms: ${duration_ms}\n` +
          `- end_time: ${new Date().toISOString()}\n` +
          (adapterError ? `\n### Adapter error\n\`\`\`\n${adapterError.slice(0, 2000)}\n\`\`\`\n` : '') +
          `- log: see \`${logPath.split(/[\\/]/).pop()}\` for raw output\n`,
      });
    } catch (err) {
      process.stderr.write(`hopper-runner: failed to write final frontmatter: ${err.message}\n`);
      process.exit(2);
    }

    // Exit code reflects queue_status semantics: 0 only if adapter parseResult said success
    process.exit(status === 'done' ? 0 : (code === null ? 1 : (code === 0 ? 1 : code)));
  });

  vendor.on('error', (err) => {
    clearTimeout(killTimer);
    fail(outputMdPath, `Vendor spawn error: ${err.message} (command: ${adapter.command})`);
  });
}

main().catch((err) => {
  process.stderr.write(`hopper-runner fatal: ${err.message}\n`);
  process.exit(2);
});
