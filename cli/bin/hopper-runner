#!/usr/bin/env node
// hopper-runner — detached wrapper owning a single vendor subprocess lifecycle
// Anchor: cli/bin/hopper-runner
//
// Per spec v2.1.0 §14.6: this wrapper is invoked exclusively by hopper-dispatch
// --background as a detached child. It then spawns the vendor adapter EXACTLY
// ONCE (non-detached, so this wrapper owns the lifecycle), waits for vendor
// exit, and atomically updates the output.md frontmatter status.
//
// Single-spawn invariant: this script contains exactly one spawn() call.
// Counter-tested in tests/integration/runner-single-spawn.test.js.

import { spawn } from 'node:child_process';
import { openSync, closeSync, readFileSync, readSync, existsSync, statSync } from 'node:fs';
import { basename, dirname } from 'node:path';
import { readFrontmatter, writeFrontmatter } from '../src/background.js';
import { appendProgressEvent, findLatestVendorProgressEvent } from '../src/progress.js';
import { finalizeTerminalAttestation } from '../src/handoff-attestation.js';
import { getAdapter } from '../src/vendors/index.js';
import { acquireVendorLock, killProcessTree, resolveDispatchTimeouts, chunkHasSubstantiveLine } from '../src/subprocess.js';
import { resolveCommandOnPath, resolveCommandWithKnownPaths } from '../src/path-resolve.js';
import { renderVendorOutputSection, writeRunnerSidecar } from '../src/output.js';

function parseRunnerArgs(argv) {
  // Format: --task-id X --hopper-dir Y --adapter Z --output-md A --log B -- <adapter argv...>
  const parsed = { adapterArgv: [] };
  let i = 0;
  let sawSeparator = false;
  while (i < argv.length) {
    const a = argv[i];
    if (sawSeparator) {
      parsed.adapterArgv.push(a);
      i++;
      continue;
    }
    if (a === '--') {
      sawSeparator = true;
      i++;
      continue;
    }
    if (a.startsWith('--')) {
      const key = a.slice(2).replace(/-([a-z])/g, (_, c) => c.toUpperCase());
      const val = argv[i + 1];
      if (val === undefined || val.startsWith('--')) {
        throw new Error(`hopper-runner: flag ${a} requires a value`);
      }
      parsed[key] = val;
      i += 2;
      continue;
    }
    throw new Error(`hopper-runner: unexpected arg ${a}`);
  }
  return parsed;
}

function terminalMessageFor(status, adapterStatus, providedMessage = null) {
  if (providedMessage) return providedMessage;
  if (status === 'done') return 'Task completed successfully.';
  if (adapterStatus === 'timeout') return 'Task timed out.';
  return 'Task failed.';
}

function terminalPhaseFor(status, adapterStatus, timedOut) {
  // A resolved success is never a timeout phase — covers the mimo idle reap-after-completion
  // (timedOut=true but the answer was fully delivered, so parseResult returned success).
  if (status === 'done') return 'done';
  if (timedOut || adapterStatus === 'timeout') return 'timeout';
  return status;
}

function runnerStartupSnapshot() {
  try {
    const parsed = JSON.parse(process.env.HOPPER_ATTESTATION_STARTUP || '');
    return parsed && typeof parsed === 'object' && !Array.isArray(parsed) ? parsed : null;
  } catch (_) {
    return null;
  }
}

function fail(outputMdPath, message, context = {}) {
  // The shared finalizer retains event-first failure semantics: append failures
  // deliberately leave frontmatter in-progress rather than inventing a terminal.
  try {
    const fm = readFrontmatter(outputMdPath);
    const endTime = new Date().toISOString();
    const duration_ms = Date.now() - Date.parse(fm.start_time || new Date().toISOString());
    finalizeTerminalAttestation({
      hopperDir: context.hopperDir || dirname(dirname(outputMdPath)),
      taskId: context.taskId || fm.task_id || basename(outputMdPath).replace(/-output\.md$/, ''),
      outputMdPath,
      startupSnapshot: runnerStartupSnapshot(),
      parsed: {},
      completion: {
        vendor: fm.adapter || context.adapterName,
        status: 'failed',
        phase: 'failed',
        message,
        source: 'runner',
        durationMs: duration_ms,
        exitCode: -1,
        adapterStatus: context.adapter_status || 'unknown-fail',
        endTime,
        bodyAppend:
          `\n## Failure (runner)\n${message}\n`,
      },
    });
  } catch (_) {
    // if we can't even write frontmatter, all we can do is exit
  }
  process.stderr.write(`hopper-runner: ${message}\n`);
  process.exit(1);
}

async function main() {
  let opts;
  try {
    opts = parseRunnerArgs(process.argv.slice(2));
  } catch (err) {
    process.stderr.write(`${err.message}\n`);
    process.exit(2);
  }

  const { taskId, hopperDir, adapter: adapterName, outputMd: outputMdPath, log: logPath, cwd: vendorCwd, adapterArgv } = opts;
  if (!taskId || !hopperDir || !adapterName || !outputMdPath || !logPath) {
    process.stderr.write('hopper-runner: missing required flags (--task-id, --hopper-dir, --adapter, --output-md, --log)\n');
    process.exit(2);
  }

  let adapter;
  try {
    adapter = getAdapter(adapterName);
  } catch (err) {
    fail(outputMdPath, err.message, { taskId, hopperDir, adapterName });
  }

  // Per codex Phase 5 audit F2: deserialize adapter opts from env var so
  // timeoutMs honors --reasoning xhigh / --model etc.
  let adapterOpts = {};
  if (process.env.HOPPER_ADAPTER_OPTS) {
    try {
      adapterOpts = JSON.parse(process.env.HOPPER_ADAPTER_OPTS);
    } catch (_) {
      adapterOpts = {};
    }
  }

  const t0 = Date.now();

  // Open log fds for vendor stdio. The runner's own stdout/stderr was already
  // redirected to logPath by the parent (hopper-dispatch). We re-open the file
  // for the vendor so its writes are tracked separately for failure analysis.
  let fdOut, fdErr;
  try {
    fdOut = openSync(logPath, 'a');
    fdErr = openSync(logPath, 'a');
  } catch (err) {
    fail(outputMdPath, `Could not open log file ${logPath}: ${err.message}`, { taskId, hopperDir, adapterName });
  }

  // STDIN prompt delivery (win-cmd-shim): read the 0600 prompt file UP FRONT so an
  // unreadable file fails fast (no wasted vendor run). The runner — the vendor's alive
  // parent — pipes these bytes to the vendor's stdin + end()s (EOF) after spawn. This is
  // NOT the banned dispatcher-stdin pipe (the dispatcher already exited; the runner owns
  // the pipe for the whole run). Bytes flow parent→OS-pipe→child untouched by cmd.exe.
  // Defense in depth: honor the stdin file ONLY for a vendor that actually declares
  // stdin support. Even if HOPPER_PROMPT_STDIN_FILE leaked into the env, a non-stdin
  // adapter (esp. agy, which hangs on an open stdin pipe) keeps stdin `'ignore'`.
  const promptStdinFile = (process.env.HOPPER_PROMPT_STDIN_FILE && adapter && adapter.promptStdin === 'supported')
    ? process.env.HOPPER_PROMPT_STDIN_FILE
    : null;
  let promptStdinBuf = null;
  if (promptStdinFile) {
    try {
      promptStdinBuf = readFileSync(promptStdinFile);
    } catch (err) {
      fail(outputMdPath, `prompt stdin file unreadable (${promptStdinFile}): ${err.message}`, { taskId, hopperDir, adapterName, status: 'prompt-delivery-fail', adapter_status: 'prompt-delivery-fail' });
      return;
    }
  }

  // Per shared cli/src/path-resolve.js: in-process PATH + PATHEXT walk
  // (no subprocess). Real .exe → spawn directly; .cmd/.bat → wrap with
  // cmd.exe /c. POSIX returns command unchanged.
  // Phase 6c F2: also consult adapter.knownInstallPaths for installers that
  // don't add their bin to PATH (agy on Windows is the motivating case).
  // This is deterministic path lookup, NOT vendor-retry orchestration.
  const resolved = resolveCommandWithKnownPaths(adapter.command, adapter.knownInstallPaths || []);
  const resolvedCmd = resolved ? resolved.command : adapter.command;
  const prependArgs = resolved ? resolved.prependArgs : [];
  const finalArgv = [...prependArgs, ...adapterArgv];

  // ISSUE-codex-bypass-flag-missing-from-argv: log the FINAL spawned argv (not
  // just the resolved opts) and the total command-line length, and warn loudly
  // when a vendor reached via a cmd.exe `.cmd`/`.bat` shim is near cmd.exe's
  // ~8191-char command-line limit. An over-long line is silently truncated by
  // cmd.exe, dropping TRAILING argv — historically codex's --sandbox /
  // --dangerously-bypass-* flags — so the vendor fell back to its default
  // sandbox and hit CreateProcessWithLogonW 1326 (a silent no-op). The codex
  // adapter now places the large prompt LAST so the flags survive truncation,
  // but this guard still surfaces the over-long condition for any vendor.
  const isWindowsHost = process.platform === 'win32';
  const viaCmdShim = isWindowsHost && (/cmd\.exe$/i.test(resolvedCmd)
    || prependArgs.some((a) => /\.(cmd|bat)$/i.test(String(a))));
  const cmdlineLen = [resolvedCmd, ...finalArgv].join(' ').length;
  if (process.env.HOPPER_DEBUG) {
    process.stderr.write(`hopper-runner: spawn command = ${resolvedCmd}\n`);
    process.stderr.write(`hopper-runner: final argv (${finalArgv.length} args, ~${cmdlineLen} chars) = ${JSON.stringify(finalArgv)}\n`);
  }
  if (viaCmdShim && cmdlineLen > 7000) {
    process.stderr.write(
      `hopper-runner: WARNING ${adapter.command} is spawned via a cmd.exe shim and the composed ` +
      `command line is ~${cmdlineLen} chars (cmd.exe limit ≈ 8191). Trailing arguments may be ` +
      `truncated, which can make ${adapter.command} ignore --sandbox/--dangerously-* and fall back ` +
      `to its default sandbox (Windows CreateProcessWithLogonW 1326 → silent no-op). Reduce the ` +
      `prompt/spec size, widen via a shorter HOPPER_VENDOR_CWD, or install ${adapter.command} as a ` +
      `native .exe on PATH (avoids the cmd.exe wrapper and its 8191-char limit).\n`
    );
  }

  let releaseVendorLock = () => {};
  let vendorLockReleased = false;
  const releaseVendorLockOnce = () => {
    if (vendorLockReleased) return;
    vendorLockReleased = true;
    releaseVendorLock();
  };

  try {
    releaseVendorLock = await acquireVendorLock(adapter.name);
  } catch (err) {
    fail(outputMdPath, `Could not acquire vendor lock: ${err.message}`, { taskId, hopperDir, adapterName });
  }

  // *** THE single spawn (spec §3 #4) ***
  // Single spawn() call. Windows command resolution above is pure-sync
  // PATH lookup (no subprocess, no execSync).
  //
  // Per codex Phase 5 F1 recheck (POSIX side): vendor MUST be detached so it
  // gets its own process group; otherwise killProcessTree(-pid) hits the
  // runner's group, not the vendor's children. Windows uses taskkill /T
  // which works without detached. detached on POSIX puts vendor in new pgrp.
  const isWindows = process.platform === 'win32';
  const vendor = spawn(resolvedCmd, finalArgv, {
    // stdin: 'pipe' ONLY for stdin delivery (the runner writes the prompt); else
    // 'ignore' (= /dev/null immediate EOF) so argv vendors — and agy, which HANGS on
    // an open stdin pipe — are unaffected. stdout/stderr stay FILE fds (no deadlock).
    stdio: [promptStdinFile ? 'pipe' : 'ignore', fdOut, fdErr],
    windowsHide: true,
    // Retro #3 fix: vendor runs in the repo root that owns .hopper/ (passed via
    // --cwd by spawnDetached), not the runner's own process.cwd(). Falls back to
    // process.cwd() only if --cwd was not supplied (older callers).
    cwd: vendorCwd || process.cwd(),
    // HOPPER-3: merge optional adapter env (e.g. codex CODEX_HOME auto-isolation)
    // over the inherited environment.
    env: { ...process.env, ...(typeof adapter.env === 'function' ? adapter.env(adapterOpts) : {}) },
    detached: !isWindows,
  });

  // Close our copies of the fds; vendor has its own.
  closeSync(fdOut);
  closeSync(fdErr);

  // STDIN delivery — observable contract (NOT best-effort): write the full prompt,
  // end() (EOF — load-bearing: codex reads stdin to completion, openai/codex#20919),
  // and record any short-write / write error so the exit handler can mark the dispatch
  // `prompt-delivery-fail` rather than silently treating a truncated/empty prompt as a
  // real run. The `stdin.on('error')` swallows EPIPE (vendor died mid-write) but RECORDS
  // it — it never crashes the runner, and it never hides the failure.
  let stdinDeliveryError = null;
  let stdinBytesWritten = 0;
  if (promptStdinFile && vendor.stdin && promptStdinBuf) {
    vendor.stdin.on('error', (e) => { if (!stdinDeliveryError) stdinDeliveryError = e; });
    try {
      vendor.stdin.write(promptStdinBuf, (err) => { if (err && !stdinDeliveryError) stdinDeliveryError = err; });
      stdinBytesWritten = promptStdinBuf.length;
      vendor.stdin.end();
    } catch (e) {
      stdinDeliveryError = e;
      try { vendor.stdin.end(); } catch (_) { /* already closed */ }
    }
  }

  let timedOut = false;
  let timeoutReason = null;
  let processCleanup = { status: 'not-needed', method: null };
  let lastHeartbeatSignature = null;
  let lastHeartbeatAt = 0;
  const appendVendorHeartbeat = (chunk) => {
    const stream = findLatestVendorProgressEvent(chunk);
    if (!stream) return;
    const now = Date.now();
    const signature = `${stream.event}:${stream.reason || ''}`;
    // Keep the file-backed protocol compact while still surfacing a new lifecycle
    // transition immediately. No raw stream data is copied into progress.
    if (signature === lastHeartbeatSignature && now - lastHeartbeatAt < 5000) return;
    const update = new Date(now).toISOString();
    try {
      const fm = readFrontmatter(outputMdPath);
      if (fm.terminal_event_emitted || (fm.status && fm.status !== 'in-progress')) return;
      const message = `Vendor ${stream.event}${stream.reason ? ` (${stream.reason})` : ''}.`;
      const event = appendProgressEvent({
        hopperDir,
        taskId,
        event: {
          vendor: fm.adapter || adapterName,
          phase: 'running',
          kind: 'heartbeat',
          message,
          source: 'vendor-stream',
          terminal: false,
          last_stream_event: stream.event,
          last_reason: stream.reason || undefined,
          last_update: update,
        },
      });
      writeFrontmatter(outputMdPath, {
        ...fm,
        phase: 'running',
        last_progress_at: event.ts,
        last_progress: event.message,
        progress_seq: event.seq,
        last_stream_event: stream.event,
        last_reason: stream.reason || null,
        last_update: update,
      });
      lastHeartbeatSignature = signature;
      lastHeartbeatAt = now;
    } catch (_) {
      // Stream progress is advisory; terminal frontmatter remains authoritative.
    }
  };
  // 乙: idle + ceiling instead of one total cap. Per codex Phase 5 audit F2,
  // adapter.timeoutMs honors --reasoning xhigh; it now SEEDS the ceiling (floored
  // to ≥30min by resolveDispatchTimeouts). The real "stuck" detector is idle:
  // the runner pipes vendor stdio straight to logPath (no in-process 'data'
  // events), so idle is measured by polling the log file for growth — silence =
  // no growth for idleMs. --timeout / HOPPER_DISPATCH_TIMEOUT_MS override the
  // ceiling; HOPPER_IDLE_TIMEOUT_MS overrides idle.
  const baselineMs = adapter.timeoutMs({ ...adapterOpts, background: true });
  let { idleMs, ceilingMs } = resolveDispatchTimeouts(baselineMs, adapterOpts);
  if (process.env.HOPPER_TEST_ONLY_TIMEOUT_MS) {
    const t = Number.parseInt(process.env.HOPPER_TEST_ONLY_TIMEOUT_MS, 10);
    if (Number.isFinite(t) && t > 0) { ceilingMs = t; idleMs = Math.min(idleMs, t); }
  }
  // Process-tree kill (not just top-level): children of .cmd wrappers + agentic
  // CLIs don't leak. taskkill /T /F on Windows; kill(-pid) on POSIX (vendor was
  // spawned detached → owns its own group).
  let killTimer = null;
  let idlePoll = null;
  let bufferedLivenessTimer = null;
  const killVendor = (reason) => {
    // Idle and ceiling are competing timeout sources. The first source owns
    // both the diagnostic and cleanup result; clear its peer before the
    // synchronous tree-kill so a timer that becomes due meanwhile cannot
    // overwrite either field or issue a second kill.
    if (timedOut) return false;
    timedOut = true;
    timeoutReason = reason;
    if (killTimer) clearTimeout(killTimer);
    if (idlePoll) clearInterval(idlePoll);
    if (bufferedLivenessTimer) clearInterval(bufferedLivenessTimer);
    processCleanup = killProcessTree(vendor.pid, isWindows);
    return true;
  };
  killTimer = setTimeout(() => killVendor('ceiling'), ceilingMs);
  killTimer.unref();
  // Buffered-output vendors (ISSUE-grok-claude-buffered-output-idle-falsekill):
  // grok/claude `--output-format json` are END-BUFFERED — the vendor writes
  // stdout ONCE at completion, so the log file never grows until the vendor is
  // already done. Arming the log-growth idle poll below for those adapters
  // degenerates into an unconditional kill ~idleMs after spawn (real kills
  // observed at 185053ms / 605213ms for idleMs=180000 / 600000 — one ~5s poll
  // tick past idleMs, every time). So: when the adapter declares
  // `bufferedOutput: true`, skip arming the idle poll entirely; the absolute
  // ceiling timer above still fully applies as the safety net.
  const bufferedOutput = Boolean(adapter && adapter.bufferedOutput === true);
  if (bufferedOutput) {
    process.stderr.write(`hopper-runner: idle watchdog disabled (bufferedOutput vendor) — ceiling-only timeout applies (${ceilingMs}ms)\n`);
  }
  // End-buffered and text-only adapters without a safe lifecycle envelope cannot
  // expose stream progress. Emit a fixed, non-sensitive process-alive marker
  // instead: no log reads, prompt, output, or idle activity clocks are involved,
  // and the absolute/idle timeout semantics are intentionally untouched. The
  // test-only override keeps integration tests fast without changing production
  // cadence.
  const DEFAULT_BUFFERED_LIVENESS_INTERVAL_MS = 30_000;
  const testLivenessMs = Number.parseInt(process.env.HOPPER_TEST_ONLY_LIVENESS_INTERVAL_MS || '', 10);
  const bufferedLivenessIntervalMs = Number.isFinite(testLivenessMs) && testLivenessMs > 0
    ? testLivenessMs
    : DEFAULT_BUFFERED_LIVENESS_INTERVAL_MS;
  const appendBufferedLiveness = () => {
    if (!vendor.pid || vendor.exitCode !== null || vendor.signalCode !== null) return;
    const update = new Date().toISOString();
    try {
      const fm = readFrontmatter(outputMdPath);
      if (fm.terminal_event_emitted || (fm.status && fm.status !== 'in-progress')) return;
      const event = appendProgressEvent({
        hopperDir,
        taskId,
        event: {
          vendor: fm.adapter || adapterName,
          phase: 'running',
          kind: 'process_alive',
          message: 'Vendor process is still running.',
          source: 'runner',
          terminal: false,
          last_stream_event: 'process_alive',
          last_update: update,
        },
      });
      writeFrontmatter(outputMdPath, {
        ...fm,
        phase: 'running',
        last_progress_at: event.ts,
        last_progress: event.message,
        progress_seq: event.seq,
        last_stream_event: 'process_alive',
        last_update: update,
      });
    } catch (_) {
      // Liveness is advisory; terminal frontmatter remains authoritative.
    }
  };
  const contentFreeProcessLiveness = adapter?.liveness?.processAlive === true
    && adapter?.liveness?.safeStreamEvents === false;
  const emitsProcessAliveLiveness = bufferedOutput || adapter?.liveness?.processAlive === true;
  bufferedLivenessTimer = emitsProcessAliveLiveness ? setInterval(
    appendBufferedLiveness,
    bufferedLivenessIntervalMs,
  ) : null;
  if (bufferedLivenessTimer && bufferedLivenessTimer.unref) bufferedLivenessTimer.unref();
  // idle poll: reset the silence clock whenever the log grows; kill after idleMs
  // of no growth. Poll cadence is a fraction of idleMs (clamped 1–5s).
  //
  // Heartbeat-aware variant: an adapter that emits an idle heartbeat to its log
  // (adapter.idleHeartbeatRe — mimo's --print-logs /session/status poll) would keep the size
  // growing forever and defeat the detector, so for those we reset the clock only on SUBSTANTIVE
  // growth (a newly-appended non-heartbeat line). This reaps a mimo background process that
  // delivered its answer but never exits (session-status hang); mimo.parseResult then classifies
  // the idle reap as success and extracts the already-captured answer from the log.
  const heartbeatRe = adapter && adapter.idleHeartbeatRe ? adapter.idleHeartbeatRe : null;
  let lastSize = -1;
  let lastReadOffset = 0;          // heartbeat-aware path: bytes already scanned for substance
  let lastGrowAt = Date.now();
  const pollMs = Math.max(1000, Math.min(idleMs || 0, 5000));
  idlePoll = (idleMs > 0 && !bufferedOutput) ? setInterval(() => {
    let sz = 0;
    try { sz = existsSync(logPath) ? statSync(logPath).size : 0; } catch (_) {}
        if (sz !== lastSize) {
          lastSize = sz;
          if (contentFreeProcessLiveness) {
            // This adapter has no safe lifecycle envelope. File growth still
            // resets the idle clock, but raw bytes are never opened or parsed.
            lastReadOffset = sz;
            lastGrowAt = Date.now();
            return;
          }
          if (sz > lastReadOffset) {
            let chunk = null;
            try {
              const fd = openSync(logPath, 'r');
              try {
                const len = sz - lastReadOffset;
                const buf = Buffer.allocUnsafe(len);
                const n = readSync(fd, buf, 0, len, lastReadOffset);
                chunk = buf.toString('utf8', 0, n);
              } finally { closeSync(fd); }
            } catch (_) { chunk = null; }
            if (chunk === null) {
              // Read failed this tick (I/O hiccup): be conservative — DON'T reap on a read error,
              // and DON'T advance the offset, so the appended bytes are re-scanned next poll (no skip).
              lastGrowAt = Date.now();
              return;
            }
            lastReadOffset = sz;
            appendVendorHeartbeat(chunk);
            if (!heartbeatRe || chunkHasSubstantiveLine(chunk, heartbeatRe)) { lastGrowAt = Date.now(); return; }
            // Only a declared heartbeat grew → fall through to the idle check.
          } else {
            // Initial empty log or a size shrink/rotation: resync and count it as activity once.
            lastReadOffset = sz; lastGrowAt = Date.now(); return;
          }
        }
    if (Date.now() - lastGrowAt >= idleMs) { clearInterval(idlePoll); killVendor('idle'); }
  }, pollMs) : null;
  if (idlePoll && idlePoll.unref) idlePoll.unref();

  // `exit` can arrive before the child stdio handles have closed. Read the
  // file-backed stream only on `close`, after EOF, so final completion records
  // cannot be lost to the exit/read race. appendRunnerTerminalEvent remains
  // idempotent if another terminal writer has already marked the task.
  vendor.on('close', (code, signal) => {
    releaseVendorLockOnce();
    clearTimeout(killTimer);
    if (idlePoll) clearInterval(idlePoll);
    if (bufferedLivenessTimer) clearInterval(bufferedLivenessTimer);
    const duration_ms = Date.now() - t0;

    // Per codex Phase 5 audit P1 #2: read log + invoke adapter.parseResult
    // so exit-0 failure modes (kimi HTTP 402, agy silent auth-fail) are
    // classified correctly. Without this, false-success status leaks through.
    let stdoutTail = '';
    let stderrTail = '';
    let logFileContent;
    try {
      if (existsSync(logPath)) {
        const full = readFileSync(logPath, 'utf-8');
        // log holds BOTH stdout and stderr interleaved; pass it as both for
        // adapters that pattern-match (kimi looks at stdout; agy at stderr/log)
        stdoutTail = full;
        stderrTail = full;
        logFileContent = full;
      }
    } catch (_) {
      // log unreadable; fall back to exit-code-only classification
    }

    let adapterStatus;
    let adapterError;
    let adapterText = '';                   // HOPPER-5: the parsed vendor answer
    let parsedResult = {};
    try {
      parsedResult = adapter.parseResult({
        exitCode: code === null ? -1 : code,
        stdout: stdoutTail,
        stderr: stderrTail,
        timedOut,
        timeoutReason,            // 'idle' | 'ceiling' | null — lets mimo classify an idle reap-after-completion as success
        durationMs: duration_ms,
        logFileContent,
      });
      adapterStatus = parsedResult.status;       // success | auth-fail | timeout | permission-fail | unknown-fail
      adapterError = parsedResult.error || null;
      adapterText = parsedResult.text || '';     // HOPPER-5: mirror into output.md body below
    } catch (err) {
      adapterStatus = 'unknown-fail';
      adapterError = `parseResult threw: ${err.message}`;
    }

    // Observable stdin contract: if the prompt was not fully delivered to the vendor,
    // the run is INVALID no matter what the vendor produced (it may have acted on a
    // truncated/empty prompt). Override to prompt-delivery-fail so it is never recorded
    // as success. (Codex review: never swallow a delivery failure.)
    if (stdinDeliveryError) {
      adapterStatus = 'prompt-delivery-fail';
      adapterError = `prompt stdin delivery failed after ${stdinBytesWritten}B: ${stdinDeliveryError.message || stdinDeliveryError}. Vendor may have received a truncated/empty prompt.`;
      adapterText = '';
    }

    // T1 (review finding #1): the BACKGROUND path must ALSO write the full-text
    // sidecar (previously only the sync --write path did), so `--result --full` can
    // surface the COMPLETE vendor answer for long review/research output. Logic +
    // threshold live in output.writeRunnerSidecar (unit-tested); best-effort here.
    writeRunnerSidecar(outputMdPath, adapterText);

    // Map adapter classification → queue-legal status (per spec §14.4)
    let status;
    if (adapterStatus === 'success') status = 'done';
    else status = 'failed';                // auth-fail / timeout / permission-fail / unknown-fail → failed

    try {
      const endTime = new Date().toISOString();
      const phase = terminalPhaseFor(status, adapterStatus, timedOut);
      const message = terminalMessageFor(status, adapterStatus);
      finalizeTerminalAttestation({
        hopperDir,
        taskId,
        outputMdPath,
        startupSnapshot: runnerStartupSnapshot(),
        parsed: parsedResult,
        completion: {
          vendor: adapterName,
          status,
          phase,
          message,
          source: 'runner',
          durationMs: duration_ms,
          exitCode: code === null ? -1 : code,
          signal: signal || null,
          adapterStatus,
          timedOut: timedOut || null,
          timeoutReason: timeoutReason || null,
          processCleanup: processCleanup.status,
          processCleanupMethod: processCleanup.method,
          endTime,
          bodyAppend:
            renderVendorOutputSection(adapterText, { rawLogName: logPath.split(/[\\/]/).pop() }) +
            `\n## Status (background completion)\n` +
            `- queue_status: ${status}\n` +
            `- adapter_status: ${adapterStatus}\n` +
            `- exit_code: ${code === null ? -1 : code}\n` +
            (signal ? `- signal: ${signal}\n` : '') +
            (timedOut ? `- timed_out: true\n` : '') +
            (timeoutReason ? `- timeout_reason: ${timeoutReason}\n` : '') +
            `- process_cleanup: ${processCleanup.status}\n` +
            (processCleanup.method ? `- process_cleanup_method: ${processCleanup.method}\n` : '') +
            `- duration_ms: ${duration_ms}\n` +
            `- end_time: ${endTime}\n` +
            (adapterError ? `\n### Adapter error\n\`\`\`\n${adapterError.slice(0, 2000)}\n\`\`\`\n` : '') +
            `- log: see \`${logPath.split(/[\\/]/).pop()}\` for raw output\n`,
        },
      });
    } catch (err) {
      process.stderr.write(`hopper-runner: failed to write final frontmatter: ${err.message}\n`);
      process.exit(2);
    }

    // Exit code reflects queue_status semantics: 0 only if adapter parseResult said success
    process.exit(status === 'done' ? 0 : (code === null ? 1 : (code === 0 ? 1 : code)));
  });

  vendor.on('error', (err) => {
    clearTimeout(killTimer);
    if (idlePoll) clearInterval(idlePoll);
    if (bufferedLivenessTimer) clearInterval(bufferedLivenessTimer);
    fail(outputMdPath, `Vendor spawn error: ${err.message} (command: ${adapter.command})`, { taskId, hopperDir, adapterName });
  });

  vendor.on('error', () => {
    releaseVendorLockOnce();
  });
}

main().catch((err) => {
  process.stderr.write(`hopper-runner fatal: ${err.message}\n`);
  process.exit(2);
});
