const args = process.argv.slice(2);
const VERSION = '0.32.0';

const __filename = fileURLToPath(import.meta.url);
const __dirname = dirname(__filename);
const RUNNER_PATH = join(__dirname, 'hopper-runner');

/** Parse the explicit recovery form without making recovery implicit. */
export function parseProbeCacheRecoveryArgs(argv, vendors) {
  const recoverCount = argv.filter((arg) => arg === '--recover-cache').length;
  const probeCount = argv.filter((arg) => arg === '--probe').length;
  if (recoverCount === 0) {
    const index = argv.indexOf('--probe');
    const target = index === -1 || !argv[index + 1] || argv[index + 1].startsWith('-') ? null : argv[index + 1];
    return { target, recoverCache: false, error: null };
  }
  if (recoverCount !== 1 || probeCount !== 1 || argv.length !== 3) {
    return { target: null, recoverCache: false, error: '--recover-cache is valid only as `--probe <vendor> --recover-cache`.' };
  }
  const probeIndex = argv.indexOf('--probe');
  const target = argv[probeIndex + 1];
  if (!target || target.startsWith('-') || !vendors.includes(target)) {
    return { target: null, recoverCache: false, error: '--recover-cache requires exactly one registered vendor after --probe.' };
  }
  return { target, recoverCache: true, error: null };
}

function printUsage() {
  console.log(`hopper-dispatch v${VERSION}`);
  console.log('');
  console.log('Usage:');
  console.log('  hopper-dispatch <task-id>                       Dispatch + spawn (sync); print result');
  console.log('  hopper-dispatch <task-id> --background          Dispatch + return immediately; result in .md (spec §14)');
  console.log('  hopper-dispatch <task-id> --write [--force]     Dispatch + write output.md (sync mode only)');
  console.log('  hopper-dispatch <task-id> --model <name>        Override vendor model (e.g. gpt-5.5, claude-opus-4-7)');
  console.log('  hopper-dispatch <task-id> --reasoning <level>   Override reasoning effort (minimal|low|medium|high|xhigh)');
  console.log('  hopper-dispatch <task-id> --sandbox <mode>      Override vendor permission (read-only|workspace-write|danger-full-access)');
  console.log('  hopper-dispatch --watch <task-id>               Tail-follow a background job until exit');
  console.log('  hopper-dispatch --progress <task-id>            Show background task phase + recent progress events');
  console.log('  hopper-dispatch --watch-events [--once] [--replay]  Stream NEW terminal task events as JSONL. The existing handoffs/');
  console.log('                                                  backlog is baselined (NOT replayed) so a (re)started watcher does not');
  console.log('                                                  re-fire history. --once: emit the first event then exit. --replay: also');
  console.log('                                                  emit the existing terminal backlog on start (the pre-fix behavior).');
  console.log('  hopper-dispatch --result <task-id> [--full]     Print completed task result (verdict body + log tail); --full prints the complete sidecar text (for long review/research output)');
  console.log('  hopper-dispatch --jobs                          List all in-progress background jobs');
  console.log('  hopper-dispatch --reap                          Re-classify stale (>24h or dead-PID) jobs as orphaned');
  console.log('  hopper-dispatch --archive [--older-than <days>] [--keep <N>] [--only-status <s,..>] [--dry-run]');
  console.log('                                                  Move TERMINAL task artifacts from handoffs/ → .hopper/archive/<date>/.');
  console.log('                                                  Never touches pending/in-progress or live-runner tasks. --result falls');
  console.log('                                                  back to the archive. --dry-run previews. Recommended: --older-than 7.');
  console.log('  hopper-dispatch --stop <task-id>                Stop a running background job (kill tree; status=cancelled)');
  console.log('  hopper-dispatch --resolve <id>                  Resolve dispatch without spawning');
  console.log('  hopper-dispatch --adhoc --task-type <t> --brief "<text>" [--vendor <v>] [--id <id>] [--background]   One-off dispatch (no queue.md row); brief IS the spec');
  console.log('  hopper-dispatch --swarm --task-type <t> --brief "<text>" --vendors <v1,v2,v3>   Fan a qualitative (read-only) task out to N vendors (panel)');
  console.log('  hopper-dispatch --init-tasks [--force]          Scaffold a .hopper/ workspace in the current directory');
  console.log('  hopper-dispatch --init-governance [--from <core>] [--force]  Seed .hopper/GOVERNANCE.md (opt-in prompt overlay)');
  console.log('  hopper-dispatch --status                        Show queue summary');
  console.log('  hopper-dispatch --smoke                         Standalone CLI smoke test');
  console.log('  hopper-dispatch --task-types                    List available task-type frames');
  console.log('  hopper-dispatch --vendors                       List registered vendor adapters');
  console.log('  hopper-dispatch --rules                          Print the GENERATED dispatch-rules matrix (> .hopper/DISPATCH.md)');
  console.log('  hopper-dispatch --check [<vendor>]              Show install + auth status (all, or single vendor)');
  console.log('  hopper-dispatch --capabilities <vendor>         Show static model/reasoning/feature support + cached data if probed');
  console.log('  hopper-dispatch --check-model <vendor> <model> [--json]  Assert model availability pre-dispatch (zero-spawn): verified (exit 0) | catalog-only (exit 2) | not-found (exit 1)');
  console.log('  hopper-dispatch --probe [<vendor>]              Run vendor introspection, write cache to ~/.hopper/cache/');
  console.log('  hopper-dispatch --probe <vendor> --recover-cache  Explicitly replace the cache before writing this probe result');
  console.log('  hopper-dispatch --models [<vendor>]             Show cached model list per vendor (run --probe first)');
  console.log('  hopper-dispatch --setup [<vendor>] [--deep]     Vendor readiness: installed/auth/models/sandbox/web-search (--doctor alias)');
  console.log('  hopper-dispatch --help                          Show this message');
  console.log('  hopper-dispatch --version                       Print version');
  console.log('');
  console.log('Adapter opts (forwarded to vendor adapter; ignored if adapter does not honor):');
  console.log('  --model <name>       Examples: gpt-5.5, claude-opus-4-7, deepseek/v4-flash, kimi-code/kimi-for-coding, xiaomi/mimo-v2.5-pro');
  console.log('                       Honored by: codex, kimi, opencode, copilot, grok, mimo, claude, agy (loose names are normalized to each vendor\'s canonical form)');
  console.log('  --reasoning <level>  minimal | low | medium | high | xhigh');
  console.log('                       Honored by: codex (model_reasoning_effort); grok + copilot (--effort, clamped); mimo (--variant, xhigh->max)');
  console.log('  --sandbox <mode>     read-only | workspace-write | danger-full-access');
  console.log('                       Default: danger-full-access; auto read-only for review/research task-types or read-only task text; global override HOPPER_DEFAULT_SANDBOX');
  console.log('  --web-search         Enable vendor web search (codex: --search live). Auto-on for prd-research / market-research task-types.');
  console.log('  --vendor <name>      Override the routed vendor (must be a registered adapter; host != vendor still enforced)');
  console.log('');
  console.log('Env: HOPPER_DIR overrides .hopper/ location');
  console.log('     HOPPER_VENDOR_CWD overrides the vendor working dir (default: repo root that owns .hopper/);');
  console.log('       widen to a monorepo/common-ancestor root so the vendor can reach external paths it must read');
  console.log('     HOPPER_DEBUG=1 prints composed prompt + raw subprocess result');
  console.log('     HOPPER_HOST_VENDOR set by Tier B/C hosts; host and vendor must differ');
}

function printSmoke() {
  console.log(`hopper standalone (CLI v${VERSION})`);
  console.log('Phase 1 Prong 3 OK — standalone CLI is callable from this terminal.');
  console.log('Dispatch resolution wired (queue parser + tasks loader + vendor router).');
  console.log('Vendor subprocess spawning lands in T-PLUGIN-05a-e (Phase 2).');
  process.exit(0);
}

function findHopperDir() {
  if (process.env.HOPPER_DIR) {
    const p = resolve(process.env.HOPPER_DIR);
    // An explicit HOPPER_DIR is authoritative: if it does not exist, report
    // "not found" rather than silently falling back to an ancestor walk
    // (which could bind to an unrelated `.hopper` such as a global cache dir).
    if (existsSync(p)) return p;
    return null;
  }
  // Walk up from cwd looking for .hopper/. A bare `.hopper` is not enough:
  // the global per-machine cache lives at ~/.hopper (see cli/src/cache.js) and
  // must not be mistaken for a workspace. Require a `handoffs/` subdir, which
  // scaffoldHopper() always creates for a real workspace.
  let cur = process.cwd();
  for (let i = 0; i < 5; i++) {
    const candidate = join(cur, '.hopper');
    if (existsSync(candidate) && existsSync(join(candidate, 'handoffs'))) return candidate;
    const parent = resolve(cur, '..');
    if (parent === cur) break;
    cur = parent;
  }
  return null;
}

async function main() {
  if (args.length === 0 || args.includes('--help') || args.includes('-h')) {
    printUsage();
    return;
  }
  if (args.includes('--version') || args.includes('-v')) {
    console.log(VERSION);
    return;
  }
  if (args.includes('--smoke')) {
    printSmoke();
    return;
  }

  const recoveryArgs = parseProbeCacheRecoveryArgs(args, listAdapters());
  if (recoveryArgs.error) {
    console.error(`Error: ${recoveryArgs.error}`);
    process.exit(1);
  }

  // Phase 6a discovery commands — project-agnostic (don't need hopperDir).
  if (args.includes('--check')) {
    const checkIdx = args.indexOf('--check');
    // Target = first non-flag token after --check, so both `--check grok --compat`
    // and `--check --compat grok` filter to grok.
    let target = null;
    for (let i = checkIdx + 1; i < args.length; i++) {
      if (!args[i].startsWith('-')) { target = args[i]; break; }
    }
    await runCheck(target, { compat: args.includes('--compat') });
    return;
  }
  // Consolidated vendor readiness ("setup"/"doctor") — one table answering
  // installed? · auth? · models? · capability fresh? · full-access? · web-search?
  if (args.includes('--setup') || args.includes('--doctor')) {
    const idx = args.indexOf('--setup') !== -1 ? args.indexOf('--setup') : args.indexOf('--doctor');
    const only = args[idx + 1] && !args[idx + 1].startsWith('-') ? args[idx + 1] : null;
    if (only && !listAdapters().includes(only)) {
      console.error(`Error: unknown vendor '${only}'. Known: ${listAdapters().join(', ')}`);
      process.exit(1);
    }
    await runSetup({ only, deep: args.includes('--deep') || args.includes('--compat') });
    return;
  }
  const capIdx = args.indexOf('--capabilities');
  if (capIdx !== -1) {
    const target = args[capIdx + 1];
    if (!target || target.startsWith('-')) {
      console.error('Error: --capabilities requires a vendor name.');
      console.error(`Available: ${listAdapters().join(', ')}`);
      process.exit(1);
    }
    runCapabilities(target);
    return;
  }
  const checkModelIdx = args.indexOf('--check-model');
  if (checkModelIdx !== -1) {
    const vendor = args[checkModelIdx + 1];
    const model = args[checkModelIdx + 2];
    const asJson = args.includes('--json');
    if (!vendor || vendor.startsWith('-') || !model || model.startsWith('-')) {
      console.error('Error: --check-model requires two positional args: <vendor> <model>.');
      console.error('Usage: hopper-dispatch --check-model <vendor> <model> [--json]');
      console.error(`Available vendors: ${listAdapters().join(', ')}`);
      process.exit(1);
    }
    if (!listAdapters().includes(vendor)) {
      console.error(`Error: unknown vendor '${vendor}'. Known: ${listAdapters().join(', ')}`);
      process.exit(1);
    }
    runCheckModel(vendor, model, { json: asJson });
    return;
  }

  // Phase 6b probe-cache commands
  if (args.includes('--probe')) {
    await runProbe(recoveryArgs.target, { recoverCache: recoveryArgs.recoverCache });
    return;
  }
  if (args.includes('--models')) {
    const modelsIdx = args.indexOf('--models');
    const target = args[modelsIdx + 1] && !args[modelsIdx + 1].startsWith('-') ? args[modelsIdx + 1] : null;
    runModels(target);
    return;
  }

  // Static registry/listing introspection — these compute purely from the adapter
  // registry (no project context), so they run from ANYWHERE, before the .hopper/ gate,
  // like --setup/--capabilities/--probe/--models. (--task-types is NOT here: it reads
  // the project's task-types and genuinely needs hopperDir.) `--vendors` is overloaded
  // as the --swarm value flag, so only treat it as the adapter-list command when
  // --swarm is absent — `--swarm … --vendors a,b,c` falls through to the swarm handler.
  if (args.includes('--vendors') && !args.includes('--swarm')) {
    console.log(`hopper-dispatch v${VERSION} — registered vendor adapters:`);
    for (const v of listAdapters()) {
      const gate = getAdapter(v)?.dispatchDisabled;
      const flag = gate
        ? (process.env[gate.enableEnv] === '1' ? ` (disabled by default — enabled via ${gate.enableEnv}=1)` : ` — ⚠️ DISABLED (set ${gate.enableEnv}=1 to override)`)
        : '';
      console.log(`  - ${v}${flag}`);
    }
    return;
  }
  if (args.includes('--rules')) {
    // GENERATED dispatch-rules matrix (single source of truth = the adapters).
    // Persist into a project: `hopper-dispatch --rules > .hopper/DISPATCH.md`.
    process.stdout.write(renderRulesMarkdown({ version: VERSION }) + '\n');
    return;
  }

  // HOPPER-4: project bootstrap — scaffolds .hopper/ in the CURRENT directory.
  // Project-agnostic (must run BEFORE the findHopperDir gate, since the whole
  // point is that no .hopper/ exists yet).
  if (args.includes('--init-tasks')) {
    runInitTasks(process.cwd(), { force: args.includes('--force') });
    return;
  }

  if (args.includes('--init-governance')) {
    const fromIdx = args.indexOf('--from');
    const from = fromIdx !== -1 && args[fromIdx + 1] && !args[fromIdx + 1].startsWith('-') ? args[fromIdx + 1] : null;
    const govHopperDir = findHopperDir();
    if (!govHopperDir) {
      console.error('Error: no .hopper/ directory found. Run --init-tasks first.');
      process.exit(1);
    }
    try {
      const res = scaffoldGovernance(govHopperDir, { from, force: args.includes('--force') });
      console.log(`hopper-dispatch v${VERSION} — governance seeded`);
      for (const p of res.written) console.log(`  (written) ${p}`);
      if (!from) {
        console.log('\nNote: no --from given. Set the Constitution pointer in .hopper/GOVERNANCE.md,');
        console.log('or re-run with --from <fable>/prompts/portable-agent-core.md to vendor a copy.');
      }
    } catch (err) {
      if (err.code === 'EHOPPEREXISTS') {
        console.error(`Error: ${err.message}`);
        process.exit(3);
      }
      console.error(`Error: ${err.message}`);
      process.exit(1);
    }
    return;
  }

  const hopperDir = findHopperDir();
  if (!hopperDir) {
    if (args.includes('--watch-events') && !process.env.HOPPER_DIR) {
      return;
    }
    console.error('Error: no .hopper/ directory found in cwd or ancestors.');
    console.error('Set HOPPER_DIR env var OR run from a directory containing .hopper/.');
    process.exit(1);
  }

  // Ad-hoc dispatch: a one-off task with NO queue.md row (the --brief IS the spec).
  // Powers the directed commands (/hopper:review|research|market) + the swarm so they
  // never have to author queue.md. Single-spawn / host!=vendor guarantees unchanged.
  if (args.includes('--adhoc')) {
    const valueAfter = (flag) => {
      const i = args.indexOf(flag);
      return i !== -1 && args[i + 1] !== undefined && !args[i + 1].startsWith('-') ? args[i + 1] : null;
    };
    const taskType = valueAfter('--task-type');
    const brief = valueAfter('--brief');
    if (!taskType || !brief) {
      console.error('Error: --adhoc requires --task-type <type> and --brief "<text>".');
      console.error('Example: hopper-dispatch --adhoc --task-type prd-research --brief "research X" --vendor codex --background');
      process.exit(2);
    }
    const vendor = valueAfter('--vendor');
    const adapterOpts = {};
    try {
      if (vendor !== null) {
        validateVendor(vendor);
        if (!listAdapters().includes(vendor)) throw new Error(`unknown vendor '${vendor}'. Registered: ${listAdapters().join(', ')}`);
      }
      if (args.includes('--web-search')) adapterOpts.webSearch = true;
      const model = valueAfter('--model'); if (model) { validateModelName(model); adapterOpts.model = model; }
      const reasoning = valueAfter('--reasoning'); if (reasoning) { validateReasoning(reasoning); adapterOpts.reasoning = reasoning; }
      const sandbox = valueAfter('--sandbox'); if (sandbox) { validateSandbox(sandbox); adapterOpts.sandbox = sandbox; }
      const timeout = valueAfter('--timeout'); if (timeout) { adapterOpts.timeoutOverrideMs = validateTimeout(timeout); }
    } catch (err) {
      console.error(`Error: ${err.message}`);
      process.exit(2);
    }
    // Synthetic id for output files (caller may pin one via --id). Date.now is fine in the CLI runtime.
    const id = valueAfter('--id') || `adhoc-${taskType}-${Date.now().toString(36)}`;
    const adhocSpec = { taskType, brief };
    console.error(`hopper-dispatch v${VERSION} — ad-hoc ${taskType} -> ${vendor || '(routed)'} [id: ${id}]`);
    if (args.includes('--background')) {
      await runBackgroundDispatch(hopperDir, id, { adapterOpts, vendorOverride: vendor, adhocSpec });
    } else {
      await runDispatch(hopperDir, id, { write: true, adapterOpts, vendorOverride: vendor, adhocSpec });
    }
    return;
  }

  // Multi-vendor SWARM (panel): fan the SAME qualitative brief out to N vendors, each as
  // its own ad-hoc background dispatch (N single-spawns, no retry; one per vendor). The
  // vendor selection + per-vendor config is confirmed HOST-side (/hopper:swarm); this just
  // executes the confirmed list with shared config (per-vendor config → N `--adhoc` calls).
  if (args.includes('--swarm')) {
    const valueAfter = (flag) => {
      const i = args.indexOf(flag);
      return i !== -1 && args[i + 1] !== undefined && !args[i + 1].startsWith('-') ? args[i + 1] : null;
    };
    const taskType = valueAfter('--task-type');
    const brief = valueAfter('--brief');
    const vendorsArg = valueAfter('--vendors');
    if (!taskType || !brief || !vendorsArg) {
      console.error('Error: --swarm requires --task-type <t> --brief "<text>" --vendors <v1,v2,...>.');
      console.error('Example: hopper-dispatch --swarm --task-type code-review-acceptance --brief "review X" --vendors codex,grok,claude');
      process.exit(2);
    }
    let panels;
    try {
      panels = planSwarm({ taskType, brief, vendors: vendorsArg, idBase: valueAfter('--id-base') });
    } catch (err) {
      console.error(`Error: ${err.message}`);
      process.exit(2);
    }
    const known = listAdapters();
    for (const p of panels) {
      if (!known.includes(p.vendor)) {
        console.error(`Error: unknown vendor '${p.vendor}' in --vendors. Registered: ${known.join(', ')}`);
        process.exit(2);
      }
    }
    // --swarm FORCES the read-only/qualitative default — never let --sandbox upgrade a
    // panel to write access (that would defeat the read-only premise the task-type gate
    // exists for). Reject it; use per-vendor --adhoc if a different sandbox is truly needed.
    if (valueAfter('--sandbox')) {
      console.error('Error: --swarm forces read-only (qualitative panel); --sandbox is not allowed.');
      process.exit(2);
    }
    const adapterOpts = {};
    try {
      if (args.includes('--web-search')) adapterOpts.webSearch = true;
      const reasoning = valueAfter('--reasoning'); if (reasoning) { validateReasoning(reasoning); adapterOpts.reasoning = reasoning; }
      // NOTE: no shared --model — a single model id is meaningless across diverse vendors;
      // per-vendor model is a host concern (the swarm command uses N --adhoc for that).
    } catch (err) {
      console.error(`Error: ${err.message}`);
      process.exit(2);
    }
    console.error(`hopper-dispatch v${VERSION} — swarm ${taskType}: ${panels.length} panelists [${panels.map((p) => p.vendor).join(', ')}]`);
    const launched = [];
    const failed = [];
    for (const p of panels) {
      try {
        await runBackgroundDispatch(hopperDir, p.id, { adapterOpts, vendorOverride: p.vendor, adhocSpec: { taskType: p.taskType, brief: p.brief }, exitOnError: false });
        launched.push(p.id);
      } catch (err) {
        // Failure isolation: one panelist failing (auth / host==vendor / etc.) must not abort
        // the rest of the panel. Collect + continue; already-launched panelists keep running.
        failed.push({ vendor: p.vendor, error: err.message });
        console.error(`  panelist ${p.vendor} did not launch: ${err.message}`);
      }
    }
    console.log('');
    if (launched.length) {
      console.log('SWARM_IDS: ' + launched.join(' '));
      console.log('Collect each panelist with: hopper-dispatch --result <id> --full');
    }
    if (failed.length) {
      console.log(`Not launched (${failed.length}/${panels.length}): ${failed.map((f) => f.vendor).join(', ')}`);
    }
    if (!launched.length) process.exit(1);
    return;
  }

  if (args.includes('--status')) {
    const summary = await getStatus(hopperDir);
    console.log(`hopper-dispatch v${VERSION} — queue summary`);
    console.log(`  Total:       ${summary.total}`);
    console.log(`  Pending:     ${summary.pending}`);
    console.log(`  In-progress: ${summary['in-progress']}`);
    console.log(`  Done:        ${summary.done}`);
    console.log(`  Failed:      ${summary.failed}`);
    console.log(`  Removed:     ${summary.removed}`);
    return;
  }

  // Background job mgmt commands (spec §14.8)
  if (args.includes('--jobs')) {
    runJobsList(hopperDir);
    return;
  }
  if (args.includes('--reap')) {
    runReap(hopperDir);
    return;
  }
  if (args.includes('--archive')) {
    // A flag PRESENT but missing its value is an error (don't silently fall back to "archive all").
    // Numeric flags accept negatives so downstream validation can reject them (e.g. --keep -1).
    const numFlag = (flag) => {
      const i = args.indexOf(flag);
      if (i === -1) return undefined;
      const v = args[i + 1];
      if (v === undefined || !/^-?\d+$/.test(v)) { console.error(`Error: ${flag} requires a numeric value.`); process.exit(2); }
      return v;
    };
    const strFlag = (flag) => {
      const i = args.indexOf(flag);
      if (i === -1) return undefined;
      const v = args[i + 1];
      if (v === undefined || v.startsWith('-')) { console.error(`Error: ${flag} requires a value.`); process.exit(2); }
      return v;
    };
    runArchiveCommand(hopperDir, {
      olderThanDays: numFlag('--older-than'),
      keep: numFlag('--keep'),
      statuses: strFlag('--only-status'),
      dryRun: args.includes('--dry-run'),
    });
    return;
  }
  const stopIdx = args.indexOf('--stop');
  if (stopIdx !== -1) {
    const taskId = args[stopIdx + 1];
    if (!taskId || taskId.startsWith('-')) {
      console.error('Error: --stop requires a task-id.');
      process.exit(2);
    }
    runStop(hopperDir, taskId);
    return;
  }
  if (args.includes('--watch-events')) {
    runWatchEvents(hopperDir, { once: args.includes('--once'), replay: args.includes('--replay') });
    return;
  }
  const watchIdx = args.indexOf('--watch');
  if (watchIdx !== -1) {
    const taskId = args[watchIdx + 1];
    if (!taskId || taskId.startsWith('-')) {
      console.error('Error: --watch requires a task-id.');
      process.exit(1);
    }
    await runWatch(hopperDir, taskId);
    return;
  }
  const progressIdx = args.indexOf('--progress');
  if (progressIdx !== -1) {
    const taskId = args[progressIdx + 1];
    if (!taskId || taskId.startsWith('-')) {
      console.error('Error: --progress requires a task-id.');
      process.exit(2);
    }
    runProgress(hopperDir, taskId);
    return;
  }
  const resultIdx = args.indexOf('--result');
  if (resultIdx !== -1) {
    // task-id = first non-flag token after --result, so `--result --full T-X` and
    // `--result T-X --full` both work.
    let taskId = null;
    for (let i = resultIdx + 1; i < args.length; i++) {
      if (!args[i].startsWith('-')) { taskId = args[i]; break; }
    }
    if (!taskId) {
      console.error('Error: --result requires a task-id.');
      process.exit(1);
    }
    runResult(hopperDir, taskId, { full: args.includes('--full') });
    return;
  }

  if (args.includes('--task-types')) {
    const types = await listTaskTypes(hopperDir);
    console.log(`hopper-dispatch v${VERSION} — available task-types:`);
    for (const t of types) console.log(`  - ${t}`);
    return;
  }

  // --resolve <id>: Phase 1 behavior (no spawn)
  const resolveIdx = args.indexOf('--resolve');
  if (resolveIdx !== -1) {
    const taskId = args[resolveIdx + 1];
    if (!taskId || taskId.startsWith('-')) {
      console.error('Error: --resolve requires a task-id argument.');
      process.exit(1);
    }
    await runResolve(hopperDir, taskId);
    return;
  }

  // Parse argv into: task-id (first bare arg), bare flags, value flags.
  // Value flags consume the next argv ("--model gpt-5.5") and must not be
  // mistaken for task-id when present elsewhere in argv.
  let parsed;
  try {
    parsed = parseDispatchArgs(args);
  } catch (err) {
    console.error(`Error: ${err.message}`);
    process.exit(2);
  }

  const { taskId, bareFlags, valueFlags } = parsed;
  if (!taskId) {
    console.error('Error: no task-id provided. Use --help for usage.');
    process.exit(1);
  }

  // Per codex Phase 4 audit P1: validate task-id + flags at CLI entry using
  // the canonical validator so every host path applies identical rules.
  try {
    validateTaskId(taskId);
    if (bareFlags.length > 0) validateDispatchFlags(bareFlags);
    if (valueFlags.model !== undefined) validateModelName(valueFlags.model);
    if (valueFlags.reasoning !== undefined) validateReasoning(valueFlags.reasoning);
    if (valueFlags.sandbox !== undefined) validateSandbox(valueFlags.sandbox);
    if (valueFlags.timeout !== undefined) validateTimeout(valueFlags.timeout);
    if (valueFlags.vendor !== undefined) validateVendor(valueFlags.vendor);
  } catch (err) {
    console.error(`Error: ${err.message}`);
    process.exit(2);
  }

  // --vendor must name a REGISTERED adapter (overrides AGENTS.md routing; host !=
  // vendor is still enforced downstream in runDispatch/runBackgroundDispatch).
  if (valueFlags.vendor !== undefined && !listAdapters().includes(valueFlags.vendor)) {
    console.error(`Error: unknown vendor '${valueFlags.vendor}'. Registered: ${listAdapters().join(', ')}`);
    process.exit(2);
  }
  const vendorOverride = valueFlags.vendor;  // undefined when not passed

  const writeFlag = bareFlags.includes('--write');
  const forceFlag = bareFlags.includes('--force');
  const backgroundFlag = bareFlags.includes('--background');
  const webSearchFlag = bareFlags.includes('--web-search');
  const adapterOpts = {};
  if (webSearchFlag) adapterOpts.webSearch = true;
  if (valueFlags.model !== undefined) adapterOpts.model = valueFlags.model;
  if (valueFlags.reasoning !== undefined) adapterOpts.reasoning = valueFlags.reasoning;
  if (valueFlags.sandbox !== undefined) adapterOpts.sandbox = valueFlags.sandbox;
  // --timeout sets the absolute ceiling (ms); idle timeout still applies under it.
  if (valueFlags.timeout !== undefined) adapterOpts.timeoutOverrideMs = validateTimeout(valueFlags.timeout);

  if (backgroundFlag) {
    await runBackgroundDispatch(hopperDir, taskId, { adapterOpts, vendorOverride });
  } else {
    await runDispatch(hopperDir, taskId, { write: writeFlag, force: forceFlag, adapterOpts, vendorOverride });
  }
}

/**
 * Parse argv into task-id + bare flags + value flags.
 * Skips meta-flags (--help, --version, --resolve, etc.) that main() handles
 * before reaching this point. Value flags consume the next argv element;
 * bare flags don't.
 */
function parseDispatchArgs(args) {
  const META_FLAGS = new Set(['--help', '-h', '--version', '-v', '--smoke', '--status',
    '--task-types', '--vendors', '--rules', '--resolve', '--watch', '--progress', '--watch-events', '--replay', '--jobs', '--reap', '--stop', '--archive',
    '--check', '--capabilities', '--check-model', '--probe', '--models', '--setup', '--doctor', '--init-tasks', '--init-governance']);
  const VALUE_FLAGS = new Set(ALLOWED_DISPATCH_VALUE_FLAGS);
  const BARE_FLAGS = new Set(ALLOWED_DISPATCH_FLAGS);

  const bareFlags = [];
  const valueFlags = {};
  let taskId = null;

  for (let i = 0; i < args.length; i++) {
    const arg = args[i];

    if (META_FLAGS.has(arg)) continue;  // handled by main() before parseDispatchArgs

    if (VALUE_FLAGS.has(arg)) {
      const v = args[i + 1];
      if (v === undefined || v.startsWith('-')) {
        throw new Error(`${arg} requires a value (got: ${v === undefined ? 'nothing' : v}).`);
      }
      // Strip leading "--" for the opt key: --model → model
      const key = arg.replace(/^--/, '');
      valueFlags[key] = v;
      i++;  // consume the value
      continue;
    }

    if (BARE_FLAGS.has(arg)) {
      bareFlags.push(arg);
      continue;
    }

    if (arg.startsWith('-')) {
      throw new Error(`Unknown flag "${arg}". Bare flags allowed: ${[...BARE_FLAGS].join(', ')}. Value flags: ${[...VALUE_FLAGS].join(', ')}.`);
    }

    // First non-flag, non-value arg becomes task-id
    if (taskId === null) {
      taskId = arg;
    } else {
      throw new Error(`Unexpected extra positional argument "${arg}" (task-id already set to "${taskId}").`);
    }
  }

  return { taskId, bareFlags, valueFlags };
}

async function runResolve(hopperDir, taskId) {
  try {
    const result = await resolveDispatch({ hopperDir, taskId });
    console.log(`hopper-dispatch v${VERSION} — resolved dispatch for ${taskId}`);
    console.log(`  Task-type: ${result.task.taskType}`);
    console.log(`  Vendor:    ${result.vendor}`);
    console.log(`  Brief:     ${result.task.brief}`);
    console.log(`  Composed prompt length: ${result.composedPrompt.length} chars`);
    if (process.env.HOPPER_DEBUG) {
      console.log('');
      console.log('=== COMPOSED PROMPT ===');
      console.log(result.composedPrompt);
      console.log('=== END PROMPT ===');
    }

    // HOPPER-1: --resolve used to print the resolved vendor verbatim even when
    // it is NOT a registered adapter — e.g. a model id like `gpt-5.5` mistakenly
    // placed in the queue.md Vendor column or the AGENTS.md preference table.
    // The failure then surfaced much later at dispatch as the opaque
    // "No vendor adapter registered for 'gpt-5.5'". Catch it at resolve time and
    // distinguish a model-in-the-Vendor-column mistake from a typo'd adapter.
    const known = listAdapters();
    if (!known.includes(result.vendor)) {
      console.error('');
      reportUnregisteredVendor(result.vendor, result.task, known);
      process.exit(1);
    }
  } catch (err) {
    console.error(`Error: ${err.message}`);
    process.exit(1);
  }
}

/**
 * HOPPER-1: emit a targeted diagnostic when a resolved vendor is not a
 * registered adapter. Adapter ids are short lowercase words (codex, kimi,
 * opencode, ...); model ids carry version digits (gpt-5.5, claude-opus-4-7) or
 * a provider namespace (deepseek/v4-flash, org/model:tag). That distinction
 * tells a "you put a model where an adapter goes" mistake apart from a typo.
 */
function reportUnregisteredVendor(vendor, task, known) {
  console.error(`Error: resolved vendor '${vendor}' is not a registered adapter.`);
  console.error(`  Registered adapters: ${known.join(', ')}`);
  const looksLikeModel = /[/:]/.test(vendor) || /\d/.test(vendor);
  if (looksLikeModel) {
    console.error(`  '${vendor}' looks like a MODEL name, not an adapter.`);
    console.error(`  The Vendor column (queue.md) and task-vendor-preference table (AGENTS.md) name`);
    console.error(`  an ADAPTER — the CLI to invoke — while the model is selected separately:`);
    console.error(`    1. put an adapter in the Vendor column for '${task.id}' (e.g. 'codex' or 'opencode'), and`);
    console.error(`    2. pass the model via the flag:  hopper-dispatch ${task.id} --model ${vendor}`);
  } else {
    console.error(`  '${vendor}' is not a known adapter — likely a typo.`);
    console.error(`  Fix the Vendor column for '${task.id}' in queue.md, or the task-vendor-preference`);
    console.error(`  table in AGENTS.md, to one of: ${known.join(', ')}.`);
  }
}

/**
 * P3a-fix: shared soft-warn helper, called from both sync and background dispatch
 * paths. Non-blocking, advisory only — vendor may have a fresh model not yet
 * probed. Caller catches any error to ensure dispatch is never blocked.
 */
function warnIfModelUnknown(vendor, model) {
  if (!model) return;
  const cached = getVendorCache(vendor);
  // HOPPER-2: a never-probed machine (no cache file, or a cache entry whose
  // model list is empty) used to get ZERO feedback for a typo'd --model. Give a
  // clear, actionable hint instead. We deliberately do NOT auto-probe here:
  // probing spawns a vendor subprocess and the dispatch path must stay
  // single-spawn and must never write the cache (spec §3 #4 + §14.6). The user
  // opts in to populating the cache via --probe.
  if (!cached || !Array.isArray(cached.models) || cached.models.length === 0) {
    console.error(`  note: no probed model cache for ${vendor}; cannot validate --model '${model}'.`);
    console.error(`  proceeding anyway. To check model names ahead of time:`);
    console.error(`  (a) RECOMMENDED — omit --model entirely; ${vendor} has an implicit default model.`);
    console.error(`  (b) Populate the cache once: \`hopper-dispatch --probe ${vendor}\`, then re-dispatch.`);
    return;
  }
  // Form-tolerant membership: a cached `xiaomi/mimo-v2.5-pro` should satisfy a
  // normalized bare `mimo-v2.5-pro` (and vice versa), matching V3/V4 canon rules.
  const inCache = cached.models.some((m) => { try { return modelKeysMatch(vendor, m, model); } catch (_) { return m === model; } });
  if (!inCache) {
    console.error(`  warn: model '${model}' not in cached list for ${vendor}`);
    console.error(`  cached models (${staleness(cached.probed_at)}): ${cached.models.slice(0, 8).join(', ')}${cached.models.length > 8 ? '...' : ''}`);
    console.error(`  proceeding anyway; three fix paths:`);
    // Phase 6c follow-up (user question 2026-05-21 "what if I don't know
    // the model name?"): generalize the omit-model hint across ALL vendors.
    // Every vendor has an implicit default — --model is optional. This
    // makes "omit --model" the first-class recommended path for users who
    // don't remember a specific model identifier.
    console.error(`  (a) RECOMMENDED — omit --model entirely; ${vendor} has an implicit default model.`);
    console.error(`      hopper-dispatch <task-id>                              # default model + default reasoning`);
    console.error(`      hopper-dispatch <task-id> --reasoning high             # default model + elevated reasoning`);
    console.error(`  (b) Refresh the cache: \`hopper-dispatch --probe ${vendor}\` (the vendor may have added '${model}' since last probe).`);
    if (vendor === 'kimi' && ['partial', 'config-only'].includes(cached.introspection_supported)) {
      console.error(`  (c) Refresh Kimi's configured aliases with \`kimi provider list --json\`, or add one to ~/.kimi-code/config.toml (legacy ~/.kimi/ for old Python kimi-cli) then re-probe:`);
      console.error(`      [models."${model}"]`);
      console.error(`      model = "kimi-for-coding"   # or another Moonshot upstream ID`);
      console.error(`      capabilities = ["thinking"]   # if your target supports thinking`);
    } else {
      console.error(`  (c) Verify the exact identifier with \`hopper-dispatch --models ${vendor}\` (or /hopper:models ${vendor}).`);
    }
  } else if (isStale(cached.probed_at)) {
    console.error(`  note: cache for ${vendor} is ${staleness(cached.probed_at)}; consider \`hopper-dispatch --probe ${vendor}\` to refresh`);
  }
}

// Dispatch may only consume an existing cache snapshot. Never infer observed
// runtime models from cache values and never probe or mutate cache here.
function attestationCatalogSnapshot(vendor, adapter) {
  const cached = getVendorCache(vendor);
  const provenance = cached?.catalog_provenance ?? cached?.catalogProvenance ?? {};
  return {
    sourceKind: provenance.source_kind ?? provenance.sourceKind ?? 'unknown',
    sourceLabel: provenance.source_label ?? provenance.sourceLabel ?? 'unknown',
    observedAt: provenance.observed_at ?? provenance.observedAt ?? null,
    freshness: provenance.freshness ?? 'unknown',
    binaryAvailability: provenance.binary_availability ?? provenance.binaryAvailability ?? 'unknown',
    binaryBasename: provenance.binary_basename ?? provenance.binaryBasename ?? null,
    binding: adapter?.selectorMetadataBinding ?? null,
  };
}

function attestationStartupSnapshot(effectiveAdapterOpts, vendor, adapter) {
  return buildAttestationStartupSnapshot({
    requestedSelector: effectiveAdapterOpts.requestedSelector,
    effectiveSelector: effectiveAdapterOpts.effectiveSelector,
    effectiveSelectorSource: effectiveAdapterOpts.effectiveSelectorSource,
    catalog: attestationCatalogSnapshot(vendor, adapter),
    selectorMetadata: adapter?.selectorMetadata ? { adapterManifest: adapter.selectorMetadata } : {},
    binding: adapter?.selectorMetadataBinding ?? null,
  });
}

async function runDispatch(hopperDir, taskId, { write = false, force = false, adapterOpts = {}, vendorOverride = null, adhocSpec = null } = {}) {
  try {
    const optsSummary = Object.keys(adapterOpts).length > 0
      ? ` [opts: ${Object.entries(adapterOpts).map(([k, v]) => `${k}=${v}`).join(', ')}]`
      : '';
    console.error(`hopper-dispatch v${VERSION} — dispatching ${taskId}${optsSummary}...`);

    const resolved = adhocSpec
      ? await resolveAdhocDispatch({ hopperDir, taskType: adhocSpec.taskType, brief: adhocSpec.brief, id: taskId, vendorOverride })
      : await resolveDispatch({ hopperDir, taskId, vendorOverride });
    const effectiveAdapterOpts = resolveAdapterOptsForTask(resolved, adapterOpts);
    if (effectiveAdapterOpts.sandbox) {
      // When the resolver overrides an EXPLICIT request (only codex does this: its -s sandbox
      // is broken on Windows, so it's pinned to full-access), say so plainly instead of
      // mislabeling the resolved value as "explicit" — the operator asked for X, got full-access.
      let source;
      if (adapterOpts.sandbox && adapterOpts.sandbox !== effectiveAdapterOpts.sandbox) {
        source = `${resolved.vendor}: -s ${adapterOpts.sandbox} unsupported here → full-access`;
      } else {
        source = adapterOpts.sandbox ? 'explicit' : 'auto';
      }
      console.error(`  permission: sandbox=${effectiveAdapterOpts.sandbox} (${source})`);
    }
    // Batch 2: policy-chain notices — model-rule/effort-policy resolution + sentinel
    // resolution + effort clamp visibility. Never blocks dispatch (advisory only).
    for (const notice of effectiveAdapterOpts.policyNotices || []) {
      console.error(`  notice: ${notice}`);
    }

    const hostVendor = process.env.HOPPER_HOST_VENDOR;
    validateHostVendorSeparation(hostVendor, resolved.vendor);
    // Dispatch gate for a capability-disabled vendor (agy headless-output) is enforced at the
    // shared spawn chokepoint executeWithAdapter() below; nothing extra needed on the sync path.

    // Soft-warn: --model passed but X not in cached list. Non-blocking. Single-
    // spawn invariant unaffected (resolveDispatch is in-process; cache read is FS).
    if (effectiveAdapterOpts.model) {
      // Warn on the NORMALIZED model (matches the --background path); otherwise a
      // user-typed `GPT-5.5` would false-warn "not in cached list" then run `gpt-5.5`.
      try { warnIfModelUnknown(resolved.vendor, effectiveAdapterOpts.model); } catch (_) { /* never block dispatch */ }
    }

    const startedAt = Date.now();
    const adapter = getAdapter(resolved.vendor);
    if (!adapter) {
      throw new Error(`unknown vendor '${resolved.vendor}'`);
    }
    const startupSnapshot = attestationStartupSnapshot(effectiveAdapterOpts, resolved.vendor, adapter);
    const result = await executeWithAdapter({ resolved, adapter, adapterOpts: effectiveAdapterOpts, hopperDir, cwd: resolveVendorCwd(hopperDir) });
    const elapsedMs = Date.now() - startedAt;

    console.log('');
    console.log('=== DISPATCH RESULT ===');
    console.log(`Task:     ${result.task.id} (${result.task.taskType})`);
    console.log(`Vendor:   ${result.vendor}`);
    console.log(`Status:   ${result.output.status}`);
    console.log(`Duration: ${elapsedMs}ms`);
    if (result.output.usage) {
      console.log(`Usage:    ${JSON.stringify(result.output.usage)}`);
    }
    console.log('');
    if (result.output.status === 'success') {
      console.log('--- OUTPUT ---');
      console.log(result.output.text);
      console.log('--- END OUTPUT ---');
    } else {
      console.log(`--- ${result.output.status.toUpperCase()} ---`);
      console.log(result.output.error || '(no error message)');
      if (result.output.text) {
        console.log('');
        console.log('--- PARTIAL OUTPUT ---');
        console.log(result.output.text);
      }
      console.log('--- END ---');
    }

    if (process.env.HOPPER_DEBUG) {
      console.log('');
      console.log('=== RAW SUBPROCESS RESULT ===');
      console.log(JSON.stringify({
        exitCode: result.raw.exitCode,
        timedOut: result.raw.timedOut,
        durationMs: result.raw.durationMs,
        stdoutLen: result.raw.stdout.length,
        stderrLen: result.raw.stderr.length,
        logFileLen: result.raw.logFileContent ? result.raw.logFileContent.length : null,
      }, null, 2));
    }

    if (write) {
      try {
        // req #3: the frontmatter `model` field must be the RESOLVED real name (V4-
        // normalized and/or sentinel-resolved), not the raw --model flag literal —
        // e.g. `--model verified-latest` must record the concrete model it resolved
        // to, not the sentinel string. effectiveAdapterOpts.model is that resolved
        // value (background dispatch already used the equivalent effectiveOpts here;
        // this was the one path still threading the pre-resolution raw flag through).
        const written = await writeOutput({ hopperDir, dispatchResult: result, force, model: effectiveAdapterOpts.model });
        // Existing sync formatting remains the body contract. Wrap it in an
        // in-progress frontmatter record, then use the same event-first
        // finalizer as hopper-runner so --write cannot skip JSONL evidence.
        const initial = readFrontmatter(written.path);
        writeFrontmatter(written.path, {
          task_id: result.task.id,
          adapter: result.vendor,
          model: effectiveAdapterOpts.model || '(vendor default)',
          ...startupSnapshot.frontmatter,
          status: 'in-progress',
          mode: 'sync',
          start_time: new Date(startedAt).toISOString(),
          end_time: null,
          terminal_event_emitted: false,
          _body: initial._body,
        });
        const terminalStatus = result.output.status === 'success' ? 'done' : 'failed';
        finalizeTerminalAttestation({
          hopperDir,
          taskId: result.task.id,
          outputMdPath: written.path,
          startupSnapshot,
          parsed: result.output,
          completion: {
            vendor: result.vendor,
            status: terminalStatus,
            phase: terminalStatus,
            message: terminalStatus === 'done' ? 'Task completed successfully.' : 'Task failed.',
            source: 'sync',
            durationMs: result.raw.durationMs ?? elapsedMs,
            exitCode: result.raw.exitCode,
            adapterStatus: result.output.status,
          },
        });
        console.log('');
        console.log('=== OUTPUT.MD WRITTEN ===');
        console.log(`Wrote: ${written.path}${written.overwritten ? ' (overwritten)' : ''}`);
        console.log('');
        console.log('--- Suggested queue.md edit ---');
        console.log(written.queueEdit);
        console.log('');
        console.log('--- Suggested COST-LOG.md row ---');
        console.log(written.costEdit);
        console.log('');
        console.log('Per spec §11 unified user-action gate: apply suggested edits only after manual review.');
      } catch (writeErr) {
        console.error(`Error writing output.md: ${writeErr.message}`);
        if (result.output.status === 'success') process.exit(2);  // distinct exit code for write failure
      }
    }

    if (result.output.status !== 'success') process.exit(1);
  } catch (err) {
    console.error(`Error: ${err.message}`);
    process.exit(1);
  }
}

// ─── Background mode (spec §14) ───────────────────────────────────────

async function runBackgroundDispatch(hopperDir, taskId, { adapterOpts = {}, vendorOverride = null, adhocSpec = null, exitOnError = true } = {}) {
  // exitOnError=false (the --swarm path) throws instead of process.exit, so a failed
  // panelist does NOT abort the rest of the panel.
  const bail = (msg, code = 1) => {
    if (exitOnError) { console.error(msg); process.exit(code); }
    const e = new Error(msg.replace(/^Error:\s*/, '')); e.exitCode = code; throw e;
  };
  // We need a resolved adapter + argv WITHOUT executing. resolveDispatch
  // returns the composed prompt; we then ask the adapter for argv.
  let resolved;
  try {
    resolved = adhocSpec
      ? await resolveAdhocDispatch({ hopperDir, taskType: adhocSpec.taskType, brief: adhocSpec.brief, id: taskId, vendorOverride })
      : await resolveDispatch({ hopperDir, taskId, vendorOverride });
  } catch (err) {
    bail(`Error: ${err.message}`, 1);
  }
  const effectiveAdapterOpts = resolveAdapterOptsForTask(resolved, adapterOpts);

  // Batch 2: policy-chain notices (model-rule/effort-policy resolution, sentinel
  // resolution, effort clamp visibility) — same source as the sync path.
  for (const notice of effectiveAdapterOpts.policyNotices || []) {
    console.error(`  notice: ${notice}`);
  }

  // P3a-fix: soft-warn also fires on --background path. Same warnIfModelUnknown
  // helper as sync dispatch; advisory only, never blocks.
  if (effectiveAdapterOpts.model) {
    try { warnIfModelUnknown(resolved.vendor, effectiveAdapterOpts.model); } catch (_) { /* never block */ }
  }

  const adapter = getAdapter(resolved.vendor);
  if (!adapter) {
    bail(`Error: unknown vendor '${resolved.vendor}'`, 1);
  }

  // Enforce host != vendor across all host adapters.
  const hostVendor = process.env.HOPPER_HOST_VENDOR;
  try {
    validateHostVendorSeparation(hostVendor, resolved.vendor);
  } catch (err) {
    bail(`Error: ${err.message}`, 1);
  }

  // Dispatch gate: a vendor disabled by capability (e.g. agy headless-output unsupported) is
  // blocked here unless explicitly opted in (covers background + swarm panelists).
  try {
    assertVendorDispatchable(resolved.vendor);
  } catch (err) {
    bail(`Error: ${err.message}`, 1);
  }

  // Adapter envPreflight gate
  const preflight = adapter.envPreflight();
  if (!preflight.ok) {
    bail(`Error: adapter ${resolved.vendor} preflight failed: ${preflight.missing.join(' | ')}`, 1);
  }
  if (preflight.missing && preflight.missing.length > 0) {
    for (const msg of preflight.missing) console.error(`Note: ${msg}`);
  }

  // Adapter stdin handling
  if (adapter.stdinMode === 'pipe') {
    console.error('Use sync mode (omit --background) for this vendor, or update the adapter to accept prompt as argv.');
    bail(`Error: adapter ${resolved.vendor} requires stdinMode='pipe'; background mode does not support stdin piping (spec §14).`, 1);
  }

  // Build argv. logFile gets injected by spawnDetached path NOT here — adapter
  // sees logFile via opts only if it needs it. For background, the log lives
  // at <task-id>-output.log next to the .md.
  const handoffDir = join(hopperDir, 'handoffs');
  const outputMdPath = join(handoffDir, `${taskId}-output.md`);
  const logPath = outputMdPath.replace(/\.md$/, '.log');
  // Phase 6c F1: thread taskType through so runner's timeoutMs() applies review floor.
  const effectiveOpts = { ...effectiveAdapterOpts, background: true, logFile: logPath, taskType: resolved.task.taskType, cwd: resolveVendorCwd(hopperDir) };
  const startupSnapshot = attestationStartupSnapshot(effectiveAdapterOpts, resolved.vendor, adapter);
  // Size-gated prompt delivery (ISSUE-codex-bypass-flag-missing-from-argv): resolve
  // the command to know the OS command-line regime (cmd.exe shim vs native .exe), and
  // if the inline command line would be too large, write handoffs/<task>-prompt.md and
  // pass the vendor a small "read this file" pointer instead of the full prompt.
  const resolvedCmd = resolveCommandWithKnownPaths(adapter.command, adapter.knownInstallPaths || []);
  const delivery = resolvePromptDelivery({
    adapter,
    composedPrompt: resolved.composedPrompt,
    opts: effectiveOpts,
    resolvedCmd: resolvedCmd ? resolvedCmd.command : adapter.command,
    prependArgs: resolvedCmd ? resolvedCmd.prependArgs : [],
    handoffsDir: handoffDir,
    taskId,
  });
  const adapterArgv = delivery.args;

  // STDIN delivery (win-cmd-shim): the runner pipes the prompt FILE into the vendor's
  // stdin. The file is required for the background path (the dispatcher has exited; the
  // runner is the live writer). A missing file = a hard delivery failure — do NOT fall
  // back to a truncated argv.
  if (delivery.channel === 'stdin' && !delivery.promptFilePath) {
    console.error(`Error: stdin prompt delivery for ${taskId} requires a prompt file but it could not be written (handoffs/ unwritable?). Aborting rather than dispatching a truncated prompt.`);
    process.exit(1);
  }

  try {
    const result = spawnDetached({
      hopperDir,
      taskId,
      adapterName: resolved.vendor,
      adapterArgv: [resolved.vendor, ...adapterArgv].slice(1), // pass argv only, adapter name passed via --adapter
      runnerPath: RUNNER_PATH,
      hostNative: hostVendor || null,
      adapterOpts: effectiveOpts,  // codex Phase 5 F2: opts → runner via env for timeoutMs
      promptStdinFile: delivery.channel === 'stdin' ? delivery.promptFilePath : null,
      startupSnapshot,
    });
    console.log('=== BACKGROUND DISPATCH STARTED ===');
    console.log(`Task:        ${taskId}`);
    console.log(`Vendor:      ${resolved.vendor}`);
    console.log(`Sandbox:     ${effectiveOpts.sandbox}`);
    if (delivery.channel === 'stdin') {
      console.log(`Prompt:      stdin <- ${delivery.promptFilePath} (full prompt piped by the runner; ${delivery.regime}, no cmd.exe truncation)`);
    } else if (delivery.fallbackReason) {
      // Pointer delivery was wanted but could not be used → INLINE with bytes > budget.
      // This is the silent-no-op risk class; surface it loudly instead of a false-healthy line.
      console.error(`WARNING: prompt-file delivery fell back to INLINE — ${delivery.fallbackReason}. Command line is ${delivery.bytes}B (budget ${delivery.budget}B, ${delivery.regime}); on Windows cmd.exe it may be truncated, dropping trailing flags.`);
      console.log(`Prompt:      inline FALLBACK (${delivery.bytes}B > ${delivery.budget}B ${delivery.regime} — see WARNING above)`);
    } else {
      console.log(`Prompt:      ${delivery.inlined
        ? `inline argv (${delivery.bytes}B <= ${delivery.budget}B ${delivery.regime})`
        : `file -> ${delivery.promptFilePath} (${delivery.bytes}B > ${delivery.budget}B ${delivery.regime})`}`);
    }
    console.log(`Runner PID:  ${result.pid}`);
    console.log(`Started at:  ${result.startTime}`);
    console.log(`Output (md): ${result.outputMdPath}`);
    console.log(`Log (raw):   ${result.logPath}`);
    console.log('');
    console.log(`Follow with: hopper-dispatch --watch ${taskId}`);
    console.log(`List jobs:   hopper-dispatch --jobs`);
  } catch (err) {
    bail(`Error: ${err.message}`, err.code === 'EALREADYRUNNING' ? 3 : 1);
  }
}

function runJobsList(hopperDir) {
  const jobs = listInProgressJobs(hopperDir);
  if (jobs.length === 0) {
    console.log('No in-progress background jobs.');
    return;
  }
  console.log(`hopper-dispatch v${VERSION} — ${jobs.length} in-progress job(s):`);
  console.log('');
  console.log('TASK ID                  VENDOR     PID     AGE     ALIVE  STARTED');
  console.log('-----------------------  ---------  ------  ------  -----  -------------------------');
  for (const job of jobs) {
    console.log(
      `${(job.task_id || '?').padEnd(23)}  ` +
      `${(job.adapter || '?').padEnd(9)}  ` +
      `${String(job.pid || '?').padEnd(6)}  ` +
      `${(isFinite(job.age_hours) ? job.age_hours.toFixed(1) + 'h' : '?').padEnd(6)}  ` +
      `${(job.alive ? 'yes' : 'no').padEnd(5)}  ` +
      `${job.start_time || '?'}`
    );
  }
  console.log('');
  console.log('Stale jobs (>24h or dead PID) can be cleaned with: hopper-dispatch --reap');
}

function runReap(hopperDir) {
  const reaped = reapStaleJobs(hopperDir);
  if (reaped.length === 0) {
    console.log('No stale jobs to reap.');
    return;
  }
  console.log(`Reaped ${reaped.length} job(s) to status=orphaned:`);
  for (const id of reaped) console.log(`  - ${id}`);
}

// Archive terminal-task artifacts out of handoffs/ into .hopper/archive/<date>/.
// Selection (the "when") is expressed via flags; the move (the "how") is in src/archive.js.
function runArchiveCommand(hopperDir, raw) {
  const olderThanDays = raw.olderThanDays != null ? Number(raw.olderThanDays) : null;
  const keep = raw.keep != null ? Number(raw.keep) : 0;
  if (olderThanDays != null && (!Number.isFinite(olderThanDays) || olderThanDays < 0)) {
    console.error('Error: --older-than requires a non-negative number of days.'); process.exit(2);
  }
  if (!Number.isInteger(keep) || keep < 0) {
    console.error('Error: --keep requires a non-negative integer.'); process.exit(2);
  }
  const statuses = raw.statuses ? raw.statuses.split(',').map((s) => s.trim()).filter(Boolean) : null;
  const dateLabel = new Date().toISOString().slice(0, 10); // YYYY-MM-DD (CLI process — Date is fine)
  const res = runArchive(hopperDir, { olderThanDays, keep, statuses, dryRun: Boolean(raw.dryRun), dateLabel });

  console.log(`hopper-dispatch v${VERSION} — archive${res.dryRun ? ' (dry-run)' : ''}`);
  console.log(`  ${res.dryRun ? 'Would archive' : 'Archived'}: ${res.archivedCount} task(s), ${res.fileCount} file(s)`
    + `${res.archivedCount ? ` → ${res.destDir}` : ''}`);
  for (const m of res.moved) console.log(`    - ${m.taskId} [${m.status}] (${m.files.length} files)${m.partial ? ' ⚠ PARTIAL — some artifacts could not be moved (left in handoffs/)' : ''}`);
  if (res.partialCount) console.log(`  ⚠ ${res.partialCount} task(s) archived partially — re-run --archive to retry the stranded files.`);
  const counts = {};
  for (const s of res.skipped) counts[s.reason] = (counts[s.reason] || 0) + 1;
  const reasons = Object.entries(counts).sort().map(([r, n]) => `${n} ${r}`).join(', ');
  if (reasons) console.log(`  Skipped: ${reasons} (in-progress / live-runner / non-terminal are never archived)`);
  if (res.dryRun) console.log('  Dry-run: nothing moved. Re-run without --dry-run to archive.');
  else if (res.archivedCount) console.log('  Results remain retrievable: `--result <id>` falls back to the archive.');
}

// HOPPER-4: scaffold a fresh .hopper/ workspace in targetDir.
function runInitTasks(targetDir, { force = false } = {}) {
  let result;
  try {
    result = scaffoldHopper(targetDir, { force });
  } catch (err) {
    if (err.code === 'EHOPPEREXISTS') {
      console.error(`Error: ${err.message}`);
      console.error('Re-run with --init-tasks --force to overwrite, or remove the existing files first.');
      process.exit(3);
    }
    console.error(`Error: ${err.message}`);
    process.exit(1);
  }
  console.log(`hopper-dispatch v${VERSION} — scaffolded .hopper/ workspace`);
  console.log(`  Location: ${result.hopperDir}${result.overwritten ? ' (overwritten)' : ''}`);
  console.log(`  Files written: ${result.written.length}`);
  console.log('');
  console.log('Next steps:');
  console.log('  1. Edit .hopper/AGENTS.md to match the vendor CLIs you have installed.');
  console.log('  2. Add tasks to .hopper/queue.md and their specs to .hopper/handoffs/leader-tasklist.md.');
  console.log('  3. Run `hopper-dispatch --status` to confirm the queue parses.');
  console.log('');
  console.log('Dispatch rules: .hopper/DISPATCH.md (GENERATED — regenerate with `hopper-dispatch --rules`).');
  console.log('Constitution pointer — paste into your project CLAUDE.md / AGENTS.md so agents read one stable place:');
  console.log('  > Dispatch contract (per-vendor --model/--reasoning/--sandbox/--timeout, perms, cwd): see');
  console.log('  > `.hopper/DISPATCH.md` (hopper-generated, do not hand-edit). Never hand-copy vendor invocation strings.');
}

// HOPPER-6: actively stop a running background job (kill tree + mark cancelled).
function runStop(hopperDir, taskId) {
  try { validateTaskId(taskId); }
  catch (err) { console.error(`Error: ${err.message}`); process.exit(2); }

  let result;
  try {
    result = stopBackgroundJob(hopperDir, taskId);
  } catch (err) {
    console.error(`Error: ${err.message}`);
    process.exit(1);
  }

  if (!result.ok) {
    if (result.already) {
      console.log(`Task ${taskId} is already terminal (status=${result.status}); nothing to stop.`);
      process.exit(0);
    }
    console.error(`Error: ${result.reason}`);
    process.exit(1);
  }

  console.log(`=== STOPPED ${taskId} ===`);
  console.log(`Status:  cancelled`);
  console.log(`PID:     ${result.pid ?? 'n/a'}`);
  const killNote = result.killed
    ? 'yes'
    : (result.killSkipped ? 'no (PID reused by another process — left alone)' : 'no (process already exited)');
  console.log(`Killed:  ${killNote}`);
}

function pathFromFrontmatter(handoffDir, value, fallbackName) {
  if (!value) return join(handoffDir, fallbackName);
  if (value.startsWith('./')) return join(handoffDir, value.slice(2));
  if (value.includes('/') || value.includes('\\')) return resolve(handoffDir, value);
  return join(handoffDir, value);
}

function formatMs(ms) {
  if (!Number.isFinite(ms)) return 'n/a';
  if (ms < 1000) return `${ms}ms`;
  return `${(ms / 1000).toFixed(1)}s (${ms}ms)`;
}

function progressEventMeta(event) {
  const meta = [];
  if (event.status) meta.push(`status=${event.status}`);
  if (event.adapter_status) meta.push(`adapter_status=${event.adapter_status}`);
  if (event.exit_code !== undefined) meta.push(`exit_code=${event.exit_code}`);
  if (event.duration_ms !== undefined) meta.push(`duration_ms=${event.duration_ms}`);
  return meta.length > 0 ? ` [${meta.join(' ')}]` : '';
}

function runProgress(hopperDir, taskId) {
  try { validateTaskId(taskId); }
  catch (err) { console.error(`Error: ${err.message}`); process.exit(2); }

  const handoffDir = join(hopperDir, 'handoffs');
  const outputMdPath = join(handoffDir, `${taskId}-output.md`);
  if (!existsSync(outputMdPath)) {
    console.error(`Error: no output file for task '${taskId}'. Has this task been dispatched?`);
    process.exit(1);
  }

  const canonical = readCanonicalAttestation({ hopperDir, taskId, outputMdPath });
  renderPublicAttestation(canonical.public, { title: `${taskId} - PROGRESS` });
}

function renderPublicAttestation(record, { title }) {
  console.log(`=== ${title} ===`);
  console.log(`Task:               ${record.taskId}`);
  console.log(`Vendor:             ${record.adapter}`);
  console.log(`Status:             ${record.displayStatus}`);
  console.log(`Phase:              ${record.phase}`);
  console.log(`Requested selector: ${record.selector.requested ?? 'n/a'}`);
  console.log(`Effective selector: ${record.selector.effective ?? 'n/a'}`);
  console.log(`Source:             ${record.selector.source ?? 'user-argv'}`);
  console.log(`Kind:               ${record.selector.kind}`);
  console.log(`Observed:           ${record.observedModels.length ? record.observedModels.join(', ') : '(none)'}`);
  console.log(`Resolution:         ${record.resolution.status}`);
  console.log(`Attestation:        ${record.attestationConsistency}`);
  console.log(`Terminal:           ${record.terminal ? 'yes' : 'no'}`);
  console.log(`Inventory:          ${renderSafeInventory(record.safeCatalog)}`);
  console.log('Recent events:');
  if (record.recentEvents.length === 0) console.log('  (none)');
  for (const event of record.recentEvents) {
    console.log(`  #${event.seq ?? '?'} ${event.phase}/${event.kind}${event.terminal ? ' terminal' : ''} status=${event.status}`);
  }
}

const TERMINAL_TASK_STATUSES = new Set(['done', 'failed', 'timeout', 'cancelled', 'orphaned']);
const WATCH_EVENTS_INTERVAL_MS = 500;
// `--watch-events --once` must never hang indefinitely (issue: progress-watch-hang).
// If no terminal event arrives within this bound, exit cleanly. Overridable via env
// for long-running tasks; default is generous but finite.
const WATCH_ONCE_MAX_WAIT_MS = Number.parseInt(process.env.HOPPER_WATCH_ONCE_TIMEOUT_MS || '1800000', 10);

function taskIdFromOutputPath(outputMdPath, fm) {
  return fm.task_id || basename(outputMdPath).replace(/-output\.md$/, '');
}

function isTerminalFrontmatter(fm) {
  return fm.terminal_event_emitted === true && TERMINAL_TASK_STATUSES.has(fm.status);
}

function listOutputMarkdownFiles(handoffDir) {
  if (!existsSync(handoffDir)) return [];
  return readdirSync(handoffDir)
    .filter((name) => name.endsWith('-output.md'))
    .sort()
    .map((name) => join(handoffDir, name));
}

function terminalPayload(handoffDir, outputMdPath, fm) {
  const taskId = taskIdFromOutputPath(outputMdPath, fm);
  return {
    type: 'hopper.task.terminal',
    task_id: taskId,
    status: fm.status,
    phase: fm.phase || fm.status,
    vendor: fm.adapter || 'unknown',
    seq: Number.isInteger(fm.progress_seq) ? fm.progress_seq : null,
    output_md: outputMdPath,
    progress_log: pathFromFrontmatter(handoffDir, fm.progress_log, `${taskId}-progress.log`),
    raw_log: pathFromFrontmatter(handoffDir, fm.raw_log || fm.log, `${taskId}-output.log`),
  };
}

export function runWatchEvents(
  hopperDir,
  {
    once = false,
    replay = false,
    notifyFn = notify,
    writeLine = (line) => console.log(line),
    exitFn = (code) => process.exit(code),
  } = {},
) {
  const handoffDir = join(hopperDir, 'handoffs');
  const watched = new Set();
  const lastSeenSeq = new Map();
  let scanTimer = null;
  let onceMaxTimer = null;
  let stopped = false;

  function cleanup(code = null) {
    if (stopped) return;
    stopped = true;
    if (scanTimer) clearInterval(scanTimer);
    if (onceMaxTimer) clearTimeout(onceMaxTimer);
    for (const outputMdPath of watched) unwatchFile(outputMdPath);
    if (code !== null) exitFn(code);
  }

  function maybeEmit(outputMdPath, { silent = false } = {}) {
    if (stopped || !existsSync(outputMdPath)) return;

    let fm;
    try {
      fm = readFrontmatter(outputMdPath);
    } catch (err) {
      console.error(`watch-events: could not read ${outputMdPath}: ${err.message}`);
      return;
    }
    if (!isTerminalFrontmatter(fm)) return;

    const taskId = taskIdFromOutputPath(outputMdPath, fm);
    const seq = Number.isInteger(fm.progress_seq) ? fm.progress_seq : 0;
    const previousSeq = lastSeenSeq.get(taskId);
    if (previousSeq !== undefined && previousSeq >= seq) return;

    lastSeenSeq.set(taskId, seq);
    // Baseline-prime: record the seq so a future change is detected as new, but do NOT emit/notify
    // for a task that was ALREADY terminal when the watcher started (prevents backlog replay).
    if (silent) return;
    const payload = terminalPayload(handoffDir, outputMdPath, fm);
    writeLine(JSON.stringify(payload));
    notifyFn({
      title: `hopper: ${taskId}`,
      message: `${fm.adapter || 'unknown'} → ${fm.status}${fm.duration_ms ? ` (${(fm.duration_ms / 1000).toFixed(1)}s)` : ''}`,
      taskId,
    }).catch(() => {});
    if (once) cleanup(0);
  }

  function watchOutput(outputMdPath, { prime = false } = {}) {
    if (watched.has(outputMdPath)) return;
    watched.add(outputMdPath);
    watchFile(outputMdPath, { interval: WATCH_EVENTS_INTERVAL_MS }, (curr, prev) => {
      if (curr.mtimeMs === prev.mtimeMs && curr.size === prev.size) return;
      maybeEmit(outputMdPath); // a CHANGE after we began watching is always a NEW transition → emit
    });
    maybeEmit(outputMdPath, { silent: prime }); // initial pass: baseline-only when priming
  }

  function scanOutputs({ prime = false } = {}) {
    for (const outputMdPath of listOutputMarkdownFiles(handoffDir)) {
      watchOutput(outputMdPath, { prime });
    }
  }

  // Streaming monitor (no --once): PRIME the baseline — record the tasks that are ALREADY terminal
  // when the watcher starts WITHOUT emitting them, so it reports only NEW terminal transitions and
  // never replays the whole handoffs/ backlog on every (re)start (which spammed one notification
  // per historical task each session). --once (current snapshot) and --replay (opt back into the old
  // emit-all behavior) keep emitting existing terminals. Matches the documented intent below: a
  // persistent monitor observes tasks that reach terminal AFTER it starts.
  scanOutputs({ prime: !once && !replay });
  scanTimer = setInterval(scanOutputs, WATCH_EVENTS_INTERVAL_MS);
  if (once) {
    // `--once` must be able to exit: don't let the scan interval keep the loop
    // alive on its own, and bound the wait so it can never hang indefinitely
    // waiting for a terminal event (issue: progress-watch-hang). A PERSISTENT
    // monitor (no --once) intentionally keeps scanTimer reffed (below) so it
    // stays alive to observe tasks dispatched AFTER it starts — e.g. when it
    // launches against an empty handoffs/.
    scanTimer.unref();
    // Nothing terminal to observe → done immediately; otherwise cap the wait.
    if (watched.size === 0) {
      cleanup(0);
      return () => cleanup();
    }
    onceMaxTimer = setTimeout(() => cleanup(0), WATCH_ONCE_MAX_WAIT_MS);
  }
  process.once('SIGINT', () => cleanup(0));
  process.once('SIGTERM', () => cleanup(0));
  return () => cleanup();
}

/**
 * Phase 6c follow-up (user request 2026-05-21): print a completed task's
 * result in the HOST session. Background dispatch returns immediately, so
 * results land in `.hopper/handoffs/<task-id>-output.md` + .log — invisible
 * to the host session without explicit retrieval. This is that retrieval.
 *
 * Format optimized for chat-readability:
 *   1. One-line summary (vendor, status, duration, exit_code)
 *   2. Output.md body (skips the auto-appended `## Status (background completion)`
 *      tail so we don't print the same status twice)
 *   3. Tail of the .log file (vendor's actual stdout — last ~3000 chars by default)
 *
 * Exit codes: 0 if status=done, 1 otherwise, 2 if task is still in-progress
 * (caller should use --watch to tail instead).
 */
function runResult(hopperDir, taskId, { full = false } = {}) {
  try { validateTaskId(taskId); }
  catch (err) { console.error(`Error: ${err.message}`); process.exit(2); }

  let outputMdPath = join(hopperDir, 'handoffs', `${taskId}-output.md`);
  if (!existsSync(outputMdPath)) {
    // Fall back to the archive — an archived task's result is still retrievable.
    const archived = findArchivedOutputMd(hopperDir, taskId);
    if (archived) {
      outputMdPath = archived;
      console.error('(reading from archive)');
    } else {
      console.error(`Error: no output file for task '${taskId}' (and none in archive). Has this task been dispatched?`);
      process.exit(1);
    }
  }

  const canonical = readCanonicalAttestation({ hopperDir, taskId, outputMdPath });

  // In-progress: tell the user explicitly and suggest --watch.
  if (canonical.displayStatus === 'in-progress') {
    console.error(`Task ${taskId} is still in-progress.`);
    console.error(`Run \`hopper-dispatch --watch ${taskId}\` to follow until done.`);
    process.exit(2);
  }

  // Terminal, crash-window, and unknown records all render safely from the
  // same event-first snapshot as --progress; only a true in-progress task exits 2.
  renderPublicAttestation(canonical.public, { title: `${taskId} — ${canonical.displayStatus.toUpperCase()}` });
  if (!full) {
    console.log('Raw output is available only with `--full`.');
    process.exit(canonical.displayStatus === 'done' ? 0 : 1);
  }
  console.log('');

  // Output.md body: read the whole file, strip frontmatter + leading auto-text,
  // and stop at "## Status (background completion)" (runner-appended).
  const raw = readFileSync(outputMdPath, 'utf-8');
  let body = raw;
  // Strip leading frontmatter
  if (body.startsWith('---\n')) {
    const closingFm = body.indexOf('\n---\n', 4);
    if (closingFm !== -1) body = body.slice(closingFm + 5);
  }
  // Trim the runner's "Output streaming to ... .log" boilerplate
  body = body.replace(/^# [^\n]+\n\nOutput streaming to[^\n]+\n+/, '');
  // Stop at runner-appended status section
  const statusIdx = body.indexOf('\n## Status (background completion)');
  if (statusIdx !== -1) body = body.slice(0, statusIdx);
  body = body.trim();

  // --full: print the complete vendor text from the sidecar raw file (research /
  // review output is often longer than the output.md preview cap). When there is no
  // sidecar, the output.md body already IS the complete text (it fit under the cap).
  const rawSidecar = outputMdPath.replace(/-output\.md$/, '-output-raw.txt');
  let sidecarText = '';
  if (existsSync(rawSidecar)) {
    try { sidecarText = readFileSync(rawSidecar, 'utf-8').trim(); } catch (_) { sidecarText = ''; }
  }
  if (sidecarText) {
    console.log(`--- FULL OUTPUT (sidecar, ${sidecarText.length} chars) ---`);
    console.log(sidecarText);
    console.log('--- END FULL OUTPUT ---');
    console.log('');
  } else if (body.length > 0) {
    // --full with an empty/unreadable sidecar falls through to the body rather than
    // printing an empty FULL OUTPUT block (review finding #3). When there is genuinely
    // no sidecar, the body IS complete (the text fit under the preview cap).
    if (existsSync(rawSidecar)) console.log('(--full: sidecar was empty/unreadable — showing the output.md body instead)');
    else console.log('(--full: no sidecar — the output.md body below IS the complete text)');
    console.log('--- OUTPUT.MD BODY ---');
    console.log(body);
    console.log('--- END BODY ---');
    console.log('');
  } else {
    console.log('(output.md body is empty — vendor likely streamed to .log; printing log tail below.)');
    console.log('');
  }

  // --full is the explicit raw-output boundary for vendors that write
  // their verdict to stdout rather than the output.md body.
  const logPath = outputMdPath.replace(/\.md$/, '.log');
  const LOG_TAIL_BYTES = 4000;
  if (existsSync(logPath)) {
    try {
      const st = statSync(logPath);
      if (st.size > 0) {
        const log = readFileSync(logPath, 'utf-8');
        const tail = log.length > LOG_TAIL_BYTES ? '... [truncated; full log at .log file] ...\n' + log.slice(-LOG_TAIL_BYTES) : log;
        console.log(`--- LOG TAIL (last ${Math.min(LOG_TAIL_BYTES, st.size)} of ${st.size} bytes) ---`);
        console.log(tail);
        console.log('--- END LOG ---');
      } else {
        console.log('(log file is empty)');
      }
    } catch (err) {
      console.error(`Could not read log file: ${err.message}`);
    }
  } else {
    console.log('(no log file found)');
  }

  process.exit(canonical.displayStatus === 'done' ? 0 : 1);
}

async function runWatch(hopperDir, taskId) {
  // Per codex Phase 5 audit P1 #3: validate task-id BEFORE constructing path
  try {
    validateTaskId(taskId);
  } catch (err) {
    console.error(`Error: ${err.message}`);
    process.exit(2);
  }
  const outputMdPath = join(hopperDir, 'handoffs', `${taskId}-output.md`);
  if (!existsSync(outputMdPath)) {
    console.error(`Error: no output file at ${outputMdPath}. Has this task been dispatched?`);
    process.exit(1);
  }

  let initialFm;
  try {
    initialFm = readFrontmatter(outputMdPath);
  } catch (err) {
    console.error(`Error reading frontmatter: ${err.message}`);
    process.exit(1);
  }

  console.error(`Watching ${taskId} (status: ${initialFm.status}, pid: ${initialFm.pid || 'n/a'})`);
  console.error(`Log: ${initialFm.log || 'n/a'}`);
  console.error('');

  // Per codex Phase 5 audit F6: if the task is ALREADY terminal at the time
  // --watch is invoked, surface result + exit immediately. Previously
  // `lastStatus = initialFm.status` made the watch loop think nothing
  // changed, so the file got tailed once and then we waited forever.
  if (initialFm.status === 'done' || initialFm.status === 'failed' || initialFm.status === 'orphaned') {
    const logPath = outputMdPath.replace(/\.md$/, '.log');
    if (existsSync(logPath)) {
      try {
        const stat = statSync(logPath);
        if (stat.size > 0) process.stdout.write(readFileSync(logPath, 'utf-8'));
      } catch (_) {}
    }
    console.error('');
    console.error(`=== TASK ${initialFm.status.toUpperCase()} ===`);
    console.error(`exit_code: ${initialFm.exit_code} | duration: ${initialFm.duration_ms}ms${initialFm.signal ? ' | signal: ' + initialFm.signal : ''}${initialFm.timed_out ? ' | TIMED OUT' : ''}`);
    process.exit(initialFm.status === 'done' ? 0 : 1);
  }

  const logPath = outputMdPath.replace(/\.md$/, '.log');
  let lastSize = 0;
  let lastStatus = initialFm.status;

  // Emit any existing log content first
  if (existsSync(logPath)) {
    try {
      const stat = statSync(logPath);
      if (stat.size > 0) {
        process.stdout.write(readFileSync(logPath, 'utf-8'));
        lastSize = stat.size;
      }
    } catch (_) {}
  }

  // Watch loop
  const handler = (curr, prev) => {
    if (curr.mtimeMs === prev.mtimeMs && curr.size === prev.size) return;
    // Read new log content
    if (existsSync(logPath)) {
      try {
        const stat = statSync(logPath);
        if (stat.size > lastSize) {
          const fd = openSync(logPath, 'r');
          const buf = Buffer.alloc(stat.size - lastSize);
          readSync(fd, buf, 0, buf.length, lastSize);
          closeSync(fd);
          process.stdout.write(buf);
          lastSize = stat.size;
        }
      } catch (_) {}
    }
    // Check status
    try {
      const fm = readFrontmatter(outputMdPath);
      if (fm.status !== lastStatus) {
        lastStatus = fm.status;
        if (fm.status === 'done' || fm.status === 'failed' || fm.status === 'orphaned') {
          unwatchFile(outputMdPath, handler);
          console.error('');
          console.error(`=== TASK ${fm.status.toUpperCase()} ===`);
          console.error(`exit_code: ${fm.exit_code} | duration: ${fm.duration_ms}ms${fm.signal ? ' | signal: ' + fm.signal : ''}${fm.timed_out ? ' | TIMED OUT' : ''}`);
          process.exit(fm.status === 'done' ? 0 : 1);
        }
      }
    } catch (_) {}
  };

  watchFile(outputMdPath, { interval: 500 }, handler);

  // Tick once now in case state is already terminal
  handler(statSync(outputMdPath), { mtimeMs: -1, size: -1 });
}

// ─── Discovery commands (Phase 6a) ────────────────────────────────────

async function runSetup({ only = null, deep = false } = {}) {
  const cacheOutcome = readCacheWithOutcome();
  if (cacheOutcome.outcome === 'malformed' || cacheOutcome.outcome === 'version-mismatch') {
    console.error(`Inventory cache diagnostic: ${cacheOutcome.diagnostic_code}`);
    console.error('Cache was not changed. Recover explicitly with `hopper-dispatch --probe <vendor> --recover-cache`.');
    process.exitCode = 1;
    return;
  }
  const rows = await buildVendorReadiness({ only, deep });
  const sum = summarizeReadiness(rows);
  const runtime = buildRuntimeReport({ version: VERSION });
  console.log(`hopper-dispatch v${VERSION} — setup & readiness`);
  console.log(`Runtime: node=${runtime.nodeOk ? 'supported' : 'unsupported'} platform=${runtime.platform}`);
  console.log(`Vendors: ${sum.ready}/${sum.total} installed+authed`);
  for (const row of rows) {
    const auth = row.authOk ? (row.authSoftWarn ? 'advisory' : 'verified') : 'unverified';
    console.log(`${row.name}: status=${row.status} auth=${auth} ${renderSafeInventory(row.inventory)}`);
  }
  console.log('Use --probe for an explicit inventory refresh.');
  return;
  const cell = (s, w) => String(s == null ? '—' : s).slice(0, w).padEnd(w);

  // ── Runtime / prerequisites (is the host itself viable?) ──────────────────
  const rt = buildRuntimeReport({ version: VERSION });
  const mark = (ok) => (ok ? '✓' : '✗');
  const hopperDir = findHopperDir();
  console.log(`hopper-dispatch v${VERSION} — setup & readiness`);
  console.log('');
  console.log('Runtime');
  console.log(`  Node             ${rt.nodeVersion} ${mark(rt.nodeOk)}${rt.nodeOk ? '' : `  (hopper needs Node >= ${rt.minNodeMajor})`}`);
  console.log(`  Platform         ${rt.platform} ${rt.arch}`);
  console.log(`  hopper-dispatch  v${VERSION} ✓`);
  console.log(`  Workspace        ${hopperDir ? `${hopperDir} ✓` : 'none in cwd — run --init-tasks to scaffold .hopper/'}`);
  console.log('');

  // ── Verdict ───────────────────────────────────────────────────────────────
  const disabledNote = sum.disabled.length ? `, ${sum.disabled.length} disabled by design (${sum.disabled.join(', ')})` : '';
  if (!rt.nodeOk) {
    console.log(`⚠ Runtime: Node ${rt.nodeVersion} is below the required v${rt.minNodeMajor} — upgrade Node before dispatching.`);
  } else if (sum.usable === sum.total) {
    console.log(`✓ Ready to dispatch — ${sum.usable}/${sum.total} vendors usable.`);
  } else if (sum.usable > 0) {
    console.log(`✓ Ready to dispatch with ${sum.usable}/${sum.total} vendors usable${disabledNote}.`);
  } else {
    console.log(`⚠ No vendors usable yet — see Next steps below.`);
  }
  console.log('');

  console.log(`Vendors (${sum.ready}/${sum.total} installed+authed)`);
  console.log('| Vendor    | Installed | Auth | Sandbox | WebSrch | Models | Caps stale |');
  console.log('|-----------|-----------|------|---------|---------|--------|------------|');
  for (const r of rows) {
    const models = r.models ? `${r.models.length} cached` : 'not probed';
    const capsState = r.capsStaleAfter ? (r.capsStale ? `STALE ${r.capsStaleAfter}` : r.capsStaleAfter) : '—';
    // 3-state auth: ok = verified (env/credential file); warn = installed + authed-but-
    // -unverifiable on disk (keychain/session) — advisory, still dispatchable; NO = hard fail.
    const authCell = r.authOk ? (r.authSoftWarn ? 'warn' : 'ok') : (r.installed ? 'NO' : '—');
    console.log(
      `| ${cell(r.name, 9)} | ${cell(r.installed ? 'yes' : 'NO', 9)} | ${cell(authCell, 4)} | `
      + `${cell(['argv', 'full', 'native'].includes(r.sandboxControl) ? r.sandboxControl : '?', 7)} | `
      + `${cell(r.webSearch, 7)} | ${cell(models, 6)} | ${cell(capsState, 10)} |`,
    );
  }
  console.log('');
  console.log('Legend: Auth=ok → verified via env var or credential file; warn → installed & assumed authed but');
  console.log('  not verifiable on disk (keychain/session-backed — still dispatchable, confirmed at run time); NO → not authed.');
  console.log('  Sandbox=argv → hopper can force read-only/full-access via flags; full → always');
  console.log('  full-access, no read-only scenario (codex; not downgradable); native → vendor');
  console.log('  enforces its own policy (not argv-downgradable). WebSrch=yes → adapter plumbs a web-search');
  console.log('  toggle (needed for research tasks): yes=available headlessly; manual=vendor can');
  console.log('  search but needs env/config; no=unsupported. Models: run `--probe <vendor>` to populate; `--rules`');
  console.log('  for the full model/effort/sandbox matrix.');

  if (sum.notInstalled.length) console.log(`\nNot installed: ${sum.notInstalled.join(', ')}  (PATH is shell-dependent on Windows — see \`--check\`)`);
  if (sum.authMissing.length) console.log(`Not authenticated (hard fail — set up auth before dispatch): ${sum.authMissing.join(', ')}  (run \`--check ${sum.authMissing[0]}\` for the fix)`);
  if (sum.capsStale.length) console.log(`Capability metadata STALE (re-verify the adapter): ${sum.capsStale.join(', ')}`);

  const notes = rows.filter((r) => r.installed && r.authNotes && r.authNotes.length);
  if (notes.length) {
    console.log('\nAuth notes:');
    for (const r of notes) for (const n of r.authNotes) console.log(`  ${r.name}: ${n}`);
  }

  if (deep) {
    console.log('\nFlag/param drift (`<vendor> --help` vs adapter-emitted flags):');
    for (const r of rows) {
      const c = r.compat;
      if (!c) { console.log(`  ${r.name.padEnd(9)} —`); continue; }
      if (!c.ran) console.log(`  ${r.name.padEnd(9)} skipped — ${c.reason}`);
      else if ((c.missing || []).length === 0) console.log(`  ${r.name.padEnd(9)} OK — ${c.present.length} expected flag(s) present`);
      else console.log(`  ${r.name.padEnd(9)} DRIFT — missing: ${c.missing.join(', ')}`);
    }

    // V3: live model catalog vs the hardcoded knownGood defaults. Formatting lives
    // in the pure setup.formatModelDrift (unit-tested); this loop is just I/O.
    console.log('\nModel catalog drift (live enumeration vs hardcoded knownGood defaults):');
    for (const r of rows) {
      const { verdict, detail } = formatModelDrift(r);
      console.log(`  ${r.name.padEnd(9)} ${verdict}${detail ? ` — ${detail}` : ''}`);
    }
    console.log('  (DRIFT is advisory: add NEW models to the adapter knownGood, or drop STALE ones. --deep also refreshed the probe cache.)');
  }

  // ── Task-type policy (batch 2 lint) ────────────────────────────────────────
  const policyReport = await buildTaskTypePolicyReport(hopperDir);
  console.log('\nTask-type policy');
  if (!policyReport.applicable) {
    console.log(`  skipped — ${policyReport.reason}`);
  } else {
    // Model rule cell only ever renders r.modelStatus ('bound'|'unbound'|'unparseable') —
    // width must fit the longest status word ('unparseable' = 11 chars) or it truncates
    // to 'unparseabl'. Adaptive to the actual rows (+ a floor at the prior fixed width
    // of 10) rather than a hand-picked constant, so a future longer status word can't
    // silently truncate again. Rendering only — buildTaskTypePolicyReport's judgment
    // logic (bound/unbound/unparseable + the two warning classes) is untouched.
    const modelColWidth = Math.max(10, ...policyReport.rows.map((r) => String(r.modelStatus).length));
    console.log('  | Task-type | Vendor | Effort policy | Model rule |');
    console.log('  |-----------|--------|----------------|------------|');
    for (const r of policyReport.rows) {
      const vendorCell = r.vendorStatus === 'bound' ? r.vendor : 'unbound';
      const effortCell = r.effortStatus === 'bound' ? r.effortValue : r.effortStatus;
      const modelCell = r.modelStatus;
      console.log(`  | ${cell(r.taskType, 24)} | ${cell(vendorCell, 8)} | ${cell(effortCell, 14)} | ${cell(modelCell, modelColWidth)} |`);
    }
    console.log('  Status vocabulary: bound (usable value) · unbound (empty/OOB `(...)` — falls through to the next');
    console.log('  chain level, not an error) · unparseable (malformed cell — falls through with a dispatch-time notice).');
    if (policyReport.warnings.length) {
      console.log('\n  Warnings:');
      for (const w of policyReport.warnings) console.log(`    ⚠ ${w}`);
    } else {
      console.log('  No policy warnings.');
    }
  }

  // ── Next steps (concrete, ordered) ─────────────────────────────────────────
  const steps = buildNextSteps(rows, sum, { hopperDir });
  if (steps.length) {
    console.log('\nNext steps');
    for (const s of steps) console.log(`  • ${s}`);
  } else {
    console.log('\nNothing to do — all installed vendors are authed and ready. Dispatch with `hopper-dispatch <task-id>`.');
  }
  if (!deep) {
    console.log('\nTip: `--setup --deep` adds per-vendor flag-drift + live model-catalog reconciliation (spawns `<vendor> --help` + a model probe once each).');
  }
}

async function runCheck(target, { compat = false } = {}) {
  const vendors = target ? [target] : listAdapters();
  if (target && !listAdapters().includes(target)) {
    console.error(`Error: unknown vendor '${target}'. Known: ${listAdapters().join(', ')}`);
    process.exit(1);
  }

  // Per codex Phase 6a strict audit P2 #6: probe each vendor ONCE; reuse
  // for both table row + notes section. Halves filesystem probes and
  // eliminates row/notes inconsistency under mid-command env/file changes.
  const results = [];
  for (const v of vendors) {
    try {
      results.push({ name: v, r: await installCheckForAdapter(v), err: null });
    } catch (err) {
      results.push({ name: v, r: null, err });
    }
  }
  const compatibility = new Map();
  if (compat) {
    for (const vendor of vendors) {
      try {
        const result = compatCheckForAdapter(vendor);
        compatibility.set(vendor, result.ran
          ? (result.missing.length === 0 ? 'compatible' : 'incompatible')
          : 'unavailable');
      } catch (_) {
        compatibility.set(vendor, 'unavailable');
      }
    }
  }

  console.log(`hopper-dispatch v${VERSION} — vendor install + auth check`);
  for (const { name: vendor, r } of results) {
    const inventory = projectInventoryEntry(vendor, {
      provenance: {
        source_kind: 'static',
        binary_availability: r?.binaryFound ? 'present' : (r ? 'missing' : 'unknown'),
        binary_basename: r?.command ?? null,
      },
      diagnostic_code: r ? 'none' : 'capability-failed',
    }, 'ok-v1');
    const status = r && ['READY', 'AUTH_NEEDED', 'NOT_INSTALLED', 'UNKNOWN'].includes(r.overallStatus)
      ? r.overallStatus
      : 'UNKNOWN';
    const auth = r?.authOk ? (r.authSoftWarn ? 'advisory' : 'verified') : 'unverified';
    const compatSummary = compat ? ` compatibility=${compatibility.get(vendor)}` : '';
    console.log(`${vendor}: status=${status} auth=${auth}${compatSummary} ${renderSafeInventory(inventory)}`);
  }
  console.log(compat
    ? 'Compatibility probes ran; raw help output is withheld from public output.'
    : 'No vendor subprocess is spawned for this check.');
  return;

  // Per codex Phase 6a strict audit P2 #2 + recheck F2 #2 tightening:
  // redact home-dir in resolved paths to avoid leaking username + install
  // layout into pasted logs. Case-insensitive comparison on Windows AND
  // separator-boundary check to avoid `/home/al` matching `/home/alice`.
  const { homedir } = await import('node:os');
  const { sep } = await import('node:path');
  const home = homedir();
  const isWin = process.platform === 'win32';
  const norm = (s) => (isWin ? s.toLowerCase() : s);
  const homeN = home ? norm(home) : null;
  const redact = (p) => {
    if (!p || !homeN) return p;
    const pN = norm(p);
    if (pN === homeN) return '~';
    if (pN.startsWith(homeN + sep.toLowerCase())) {
      return '~' + p.slice(home.length);
    }
    return p;
  };

  console.log(`hopper-dispatch v${VERSION} — vendor install + auth check`);
  console.log('');
  console.log('| Vendor    | Command resolution                                 | Auth      | Status         |');
  console.log('|-----------|----------------------------------------------------|-----------|----------------|');
  for (const { name: v, r, err } of results) {
    if (err) {
      // Defensive: if a non-Error is thrown, err.message might be undefined.
      const errMsg = String((err && err.message) || err || 'unknown');
      console.log(`| ${v.padEnd(9)} | ERROR: ${errMsg.slice(0, 40).padEnd(40)} |           | ERROR          |`);
      continue;
    }
    const cmd = r.binaryFound
      ? `${redact(r.resolvedPath) || r.command}${r.needsShellWrap ? ' (cmd.exe /c wrap)' : ''}`
      : '(not on PATH)';
    // 3-state, consistent with --setup: OK (verified) / warn (soft-warn, keychain-backed) / NO (hard fail).
    const auth = r.authOk ? (r.authSoftWarn ? 'warn' : 'OK') : (r.binaryFound ? 'NO' : '—');
    console.log(`| ${v.padEnd(9)} | ${cmd.slice(0, 50).padEnd(50)} | ${auth.padEnd(9)} | ${r.overallStatus.padEnd(14)} |`);
  }
  console.log('');
  console.log('Notes (auth):');
  for (const { name: v, r } of results) {
    if (r && r.authNotes.length > 0) {
      console.log(`  ${v}:`);
      for (const note of r.authNotes) console.log(`    - ${note}`);
    }
  }
  console.log('');
  if (compat) {
    console.log('Note: --compat spawns `<vendor> --help` once per vendor (diagnostic only, off the dispatch path).');
  } else {
    console.log('No vendor subprocess is spawned for this check (spec §3 #4 single-spawn proof preserved).');
  }
  console.log('Paths shown with `~` home-dir redaction. PATH is trusted input — review your $PATH if unsure.');

  // Per Phase 6a dogfood 2026-05-21: emit diagnostic hint when any vendor
  // reports NOT_INSTALLED. PATH coverage varies between shells on Windows
  // (PowerShell sees more entries than Git-Bash/MSYS2 by default).
  const notInstalled = results.filter(({ r }) => r && r.overallStatus === 'NOT_INSTALLED');
  if (notInstalled.length > 0) {
    console.log('');
    console.log('Diagnostic — NOT_INSTALLED vendors:');
    console.log('  PATH coverage is shell-dependent on Windows. If you can run the vendor');
    console.log('  from PowerShell but `--check` reports NOT_INSTALLED in Git-Bash/MSYS2,');
    console.log('  the binary likely lives in a Windows-app install dir that PowerShell sees');
    console.log('  on PATH but your shell does not (e.g. ~/AppData/Local/<vendor>/bin/).');
    console.log('  Either: (a) run hopper-dispatch from PowerShell, or');
    console.log('          (b) add the vendor bin dir to your shell PATH.');
  }

  // --compat: spawn `<vendor> --help` and verify the flags the adapter emits
  // still exist, catching CLI-version drift before a dispatch silently fails.
  if (compat) {
    console.log('');
    console.log('Flag compatibility (`<vendor> --help` vs adapter-emitted flags):');
    for (const { name: v } of results) {
      let c;
      try {
        c = compatCheckForAdapter(v);
      } catch (err) {
        console.log(`  ${v.padEnd(9)} ERROR — ${(err && err.message) || err}`);
        continue;
      }
      if (!c.ran) {
        console.log(`  ${v.padEnd(9)} skipped — ${c.reason}`);
      } else if (c.missing.length === 0) {
        console.log(`  ${v.padEnd(9)} OK — all ${c.present.length} expected flag(s) present in --help`);
      } else {
        console.log(`  ${v.padEnd(9)} DRIFT — missing: ${c.missing.join(', ')} | present: ${c.present.join(', ') || 'none'}`);
      }
    }
    console.log('');
    console.log('Verify model aliases with `hopper-dispatch --probe <vendor>` then `--models <vendor>`');
    console.log('  (kimi resolves -m against ~/.kimi-code/config.toml; grok uses a static catalog).');
  }
}

function runCapabilities(vendor) {
  if (!listAdapters().includes(vendor)) {
    console.error(`Error: unknown vendor '${vendor}'. Known: ${listAdapters().join(', ')}`);
    process.exit(1);
  }
  const caps = capabilitiesForAdapter(vendor);
  if (!caps) {
    console.error(`Vendor '${vendor}' has no capabilities() metadata yet (Phase 6a adapter pending).`);
    process.exit(1);
  }
  const cacheOutcome = readCacheWithOutcome();
  if (cacheOutcome.outcome === 'malformed' || cacheOutcome.outcome === 'version-mismatch') {
    console.error(`Inventory cache diagnostic: ${cacheOutcome.diagnostic_code}`);
    console.error('Cache was not changed. Recover explicitly with `hopper-dispatch --probe <vendor> --recover-cache`.');
    process.exitCode = 1;
    return;
  }

  const cached = cacheOutcome.cache?.vendors?.[vendor] || null;
  const inventory = projectInventoryEntry(vendor, cached || {
    provenance: { source_kind: 'static', binary_availability: 'unknown', binary_basename: null },
  }, cacheOutcome.outcome);
  console.log(`hopper-dispatch v${VERSION} — capabilities for ${vendor}`);
  console.log(`Inventory: ${renderSafeInventory(inventory)}`);
  console.log('Selector metadata: declared');
  console.log('No vendor subprocess is spawned for this lookup (static data only).');
}

/**
 * --check-model <vendor> <model> — zero-spawn assertion pre-check (see cli/src/model-check.js
 * for the full verdict semantics). Vendor is pre-validated as a registered adapter by main().
 * Reads only capabilitiesForAdapter() (static) + getVendorCache() (probe cache, read-only) —
 * no vendor subprocess spawn, no cache write.
 */
function runCheckModel(vendor, model, { json = false } = {}) {
  const caps = capabilitiesForAdapter(vendor);
  const knownGood = (caps && caps.modelArg && caps.modelArg.knownGood) || [];
  const cacheOutcome = readCacheWithOutcome();
  const cached = cacheOutcome.cache?.vendors?.[vendor] || null;
  const catalog = (cached && Array.isArray(cached.models)) ? cached.models : null;
  const inventory = projectInventoryEntry(vendor, cached || {
    provenance: { source_kind: 'static', binary_availability: 'unknown', binary_basename: null },
  }, cacheOutcome.outcome);

  const result = evaluateModelCheck(vendor, model, knownGood, catalog);

  if (json) {
    console.log(JSON.stringify({
      vendor: result.vendor,
      model: result.model,
      normalized: result.normalized,
      verdict: result.verdict,
      selector_valid: result.selector_valid,
      runtime_attestation: result.runtime_attestation,
      exit_code: result.exitCode,
      inventory,
    }));
    process.exit(result.exitCode);
  }

  console.log(`hopper-dispatch v${VERSION} — check-model ${vendor} '${model}'`);
  if (result.normalized !== result.model) console.log(`  normalized: ${result.normalized}`);
  console.log(`  verdict: ${result.verdict}  (exit ${result.exitCode})`);
  console.log(`  selector_valid: ${result.selector_valid}`);
  console.log(`  runtime_attestation: ${result.runtime_attestation}`);
  console.log(`  inventory: ${renderSafeInventory(inventory)}`);
  console.log('No vendor subprocess is spawned for this check (static known-good + probe-cache read only).');
  process.exit(result.exitCode);
}

// ─── Phase 6b commands ────────────────────────────────────────────────

async function runProbe(target, { recoverCache: shouldRecoverCache = false } = {}) {
  const vendors = target ? [target] : listAdapters();
  if (target && !listAdapters().includes(target)) {
    console.error(`Error: unknown vendor '${target}'. Known: ${listAdapters().join(', ')}`);
    process.exit(1);
  }

  const cacheOutcome = readCacheWithOutcome();
  if ((cacheOutcome.outcome === 'malformed' || cacheOutcome.outcome === 'version-mismatch') && !shouldRecoverCache) {
    console.error(`Inventory cache diagnostic: ${cacheOutcome.diagnostic_code}`);
    console.error('Cache was not changed. Recover explicitly with `hopper-dispatch --probe <vendor> --recover-cache`.');
    process.exitCode = 1;
    return;
  }

  console.log(`hopper-dispatch v${VERSION} — probing ${vendors.length} vendor(s)...`);
  console.log('Per spec §3 #4 + §14.6 carve-out: --probe is opt-in, diagnostic,');
  console.log('single-attempt-per-vendor. Results cached at ~/.hopper/cache/vendor-capabilities.json.');
  console.log('');

  let totalSubprocesses = 0;
  for (const v of vendors) {
    process.stderr.write(`  ${v.padEnd(9)} ... `);
    const start = Date.now();
    try {
      const result = await probeVendor(v);
      const entry = { ...result, probed_at: new Date().toISOString() };
      if (shouldRecoverCache) {
        const recovery = recoverCache({ vendor: v, entry });
        if (!recovery.committed || recovery.diagnostic_code !== 'none') {
          process.stderr.write(`${recovery.diagnostic_code}\n`);
          if (!recovery.committed) {
            process.exitCode = 1;
            continue;
          }
        }
      } else {
        const write = setVendorCache(v, entry);
        if (!write.written) {
          process.stderr.write(`${write.diagnostic_code}; use --recover-cache for explicit recovery\n`);
          process.exitCode = 1;
          continue;
        }
      }
      const elapsed = Date.now() - start;
      const modelCount = result.models ? result.models.length : 0;
      process.stderr.write(`${result.introspection_supported} | ${modelCount} model(s) | ${elapsed}ms\n`);
      totalSubprocesses += estimateSpawns(v, result.introspection_supported);
    } catch (err) {
      process.stderr.write(`ERROR: ${err.message}\n`);
    }
  }

  console.log('');
  console.log(`Probe complete. ~${totalSubprocesses} vendor subprocess(es) spawned total.`);
  console.log(`Run \`hopper-dispatch --models\` or \`--capabilities <vendor>\` to read cached results.`);
}

function estimateSpawns(vendorName, introspectionSupported) {
  // N1-fix: per-vendor counts instead of bucketed approximation.
  // codex: --version + debug models = 2
  // opencode: --version + models + auth list = 3
  // copilot: version = 1 (plus zero-spawn FS scan)
  // kimi: --version + provider list = 2 when installed; config fallback = 0
  // mimo: --version + models + auth list = 3
  // grok: `grok models` = 1 (V3: live-parsed, was static/0 — see
  //   ISSUE-grok-model-line-rotation-stale-knownGood.md)
  // agy: static = 0
  if (vendorName === 'opencode') return 3;
  if (vendorName === 'mimo') return 3;
  if (vendorName === 'codex') return 2;
  if (vendorName === 'copilot') return 1;
  if (vendorName === 'kimi') return 2;
  if (vendorName === 'grok') return 1;
  // Fall back to the introspection-level approximation for unknown vendors
  switch (introspectionSupported) {
    case 'full': return 2;
    case 'partial': return 1;
    case 'config-only': return 0;
    case 'none': return 0;
    default: return 0;
  }
}

function runModels(target) {
  const { cache, outcome, diagnostic_code: diagnosticCode } = readCacheWithOutcome();
  if (outcome === 'malformed' || outcome === 'version-mismatch') {
    console.error(`Inventory cache diagnostic: ${diagnosticCode}`);
    console.error('Cache was not changed. Recover explicitly with `hopper-dispatch --probe <vendor> --recover-cache`.');
    process.exit(1);
  }
  if (!cache) {
    console.error('No cache found. Run `hopper-dispatch --probe` first to populate it.');
    process.exit(1);
  }
  const vendors = target ? [target] : Object.keys(cache.vendors);
  if (target && !cache.vendors[target]) {
    console.error(`No cached entry for vendor '${target}'. Run \`hopper-dispatch --probe ${target}\` first.`);
    console.error(`Cached vendors: ${Object.keys(cache.vendors).join(', ') || '(none)'}`);
    process.exit(1);
  }

  console.log(`hopper-dispatch v${VERSION} — cached models per vendor`);

  for (const v of vendors) {
    const entry = cache.vendors[v];
    if (!entry) continue;
    const inventory = projectInventoryEntry(v, entry, outcome);
    console.log(`${v}: ${renderSafeInventory(inventory)}`);
  }
}

if (process.argv[1] && resolve(process.argv[1]) === __filename) {
  main().catch((err) => {
    console.error(`Fatal: ${err.message}`);
    process.exit(1);
  });
}
